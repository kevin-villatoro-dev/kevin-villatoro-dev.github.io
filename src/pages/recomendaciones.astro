---
import Layout from '../layouts/Layout.astro';
import PdfViewerStyles from '../components/PdfViewerStyles.astro';
---

<Layout title="Recomendaciones - Kevin Villatoro">
  <PdfViewerStyles />
  <div class="rec-viewer">
    <div class="pdf-header-bar">
      <a href="/" class="pdf-back-link">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        Volver
      </a>
      <h1 class="pdf-title">Cartas de Recomendación</h1>
      <div class="page-indicator">
        <span id="current-page">1</span> / <span id="total-pages">0</span>
      </div>
    </div>

    <div class="carousel-container">
      <button class="nav-btn nav-prev" id="prev-btn" disabled>
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
      </button>

      <div class="pages-viewport" id="pages-viewport">
        <div class="loading-state" id="loading">
          <div class="pdf-wave-loader">
            <div class="pdf-wave-bar"></div>
            <div class="pdf-wave-bar"></div>
            <div class="pdf-wave-bar"></div>
            <div class="pdf-wave-bar"></div>
            <div class="pdf-wave-bar"></div>
          </div>
          <span class="wave-text">Cargando recomendaciones...</span>
        </div>
      </div>

      <button class="nav-btn nav-next" id="next-btn">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
      </button>
    </div>

    <div class="dots-container" id="dots-container"></div>

    <div class="floating-shapes">
      <div class="shape shape-1"></div>
      <div class="shape shape-2"></div>
      <div class="shape shape-3"></div>
    </div>
  </div>

  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js" define:vars={{}}></script>
  <script is:inline>
    pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';
    
    let currentPage = 0;
    let pages = [];
    let totalPages = 0;
    
    function updateUI() {
      document.getElementById('current-page').textContent = currentPage + 1;
      document.getElementById('prev-btn').disabled = currentPage === 0;
      document.getElementById('next-btn').disabled = currentPage === totalPages - 1;
      
      document.querySelectorAll('.dot').forEach((dot, i) => {
        dot.classList.toggle('active', i === currentPage);
      });
      
      document.querySelectorAll('.page-slide').forEach((slide, i) => {
        slide.classList.toggle('active', i === currentPage);
      });
    }
    
    document.getElementById('prev-btn').addEventListener('click', () => {
      if (currentPage > 0) {
        currentPage--;
        updateUI();
      }
    });
    
    document.getElementById('next-btn').addEventListener('click', () => {
      if (currentPage < totalPages - 1) {
        currentPage++;
        updateUI();
      }
    });
    
    async function renderPDF(url) {
      try {
        const pdf = await pdfjsLib.getDocument(url).promise;
        const viewport = document.getElementById('pages-viewport');
        const loading = document.getElementById('loading');
        const dotsContainer = document.getElementById('dots-container');
        
        totalPages = pdf.numPages;
        document.getElementById('total-pages').textContent = totalPages;
        
        for (let i = 1; i <= pdf.numPages; i++) {
          const page = await pdf.getPage(i);
          const scale = 1.4;
          const pageViewport = page.getViewport({ scale });
          
          const slide = document.createElement('div');
          slide.className = 'page-slide';
          
          const pageLabel = document.createElement('div');
          pageLabel.className = 'page-label';
          pageLabel.innerHTML = `
            <span class="page-number">${i}</span>
            <span class="page-title">Recomendación ${i}</span>
          `;
          
          const canvasWrapper = document.createElement('div');
          canvasWrapper.className = 'canvas-wrapper';
          
          const pageCanvas = document.createElement('canvas');
          pageCanvas.height = pageViewport.height;
          pageCanvas.width = pageViewport.width;
          
          await page.render({ canvasContext: pageCanvas.getContext('2d'), viewport: pageViewport }).promise;
          
          canvasWrapper.appendChild(pageCanvas);
          slide.appendChild(pageLabel);
          slide.appendChild(canvasWrapper);
          viewport.appendChild(slide);
          
          const dot = document.createElement('button');
          dot.className = 'dot';
          dot.addEventListener('click', () => {
            currentPage = i - 1;
            updateUI();
          });
          dotsContainer.appendChild(dot);
          
          pages.push(slide);
        }
        
        loading.classList.add('hidden');
        updateUI();
      } catch (error) {
        console.error('Error loading PDF:', error);
      }
    }
    
    renderPDF('/recomendaciones_kevin_villatoro.pdf');
  </script>
</Layout>

<style>
  .rec-viewer {
    height: 100vh;
    display: flex;
    flex-direction: column;
    background: var(--bg-primary);
    position: relative;
    overflow: hidden;
  }

  .rec-viewer .pdf-header-bar {
    animation: fadeSlideIn 0.6s ease-out;
  }

  @keyframes fadeSlideIn {
    from { opacity: 0; transform: translateY(-20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .rec-viewer .pdf-back-link:hover {
    color: var(--accent-magenta);
    border-color: var(--accent-magenta);
    background: rgba(255, 0, 170, 0.1);
    transform: translateX(-5px);
  }

  .rec-viewer .pdf-title {
    color: var(--accent-magenta);
    text-shadow: 0 0 30px rgba(255, 0, 170, 0.3);
    animation: titlePulse 3s ease-in-out infinite;
  }

  @keyframes titlePulse {
    0%, 100% { text-shadow: 0 0 30px rgba(255, 0, 170, 0.3); }
    50% { text-shadow: 0 0 50px rgba(255, 0, 170, 0.5), 0 0 80px rgba(0, 212, 255, 0.3); }
  }

  .page-indicator {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    background: rgba(255, 0, 170, 0.1);
    border: 1px solid rgba(255, 0, 170, 0.3);
    border-radius: var(--radius-full);
    color: var(--accent-magenta);
    font-size: 0.95rem;
    font-weight: 500;
  }

  #current-page {
    font-weight: 700;
    font-size: 1.2rem;
    color: var(--accent-cyan);
  }

  .carousel-container {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    padding: 1rem 2rem;
    min-height: 0;
  }

  .nav-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 50px;
    height: 50px;
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: 50%;
    color: var(--text-primary);
    cursor: pointer;
    transition: all var(--transition-normal);
    flex-shrink: 0;
  }

  .nav-btn:hover:not(:disabled) {
    background: rgba(255, 0, 170, 0.2);
    border-color: var(--accent-magenta);
    transform: scale(1.1);
    box-shadow: 0 0 20px rgba(255, 0, 170, 0.4);
  }

  .nav-btn:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .nav-btn:active:not(:disabled) {
    transform: scale(0.95);
  }

  .pages-viewport {
    flex: 1;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
    max-width: 900px;
  }

  .page-slide {
    position: absolute;
    width: 100%;
    opacity: 0;
    transform: translateX(100px) scale(0.9);
    transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    pointer-events: none;
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
  }

  .page-slide.active {
    opacity: 1;
    transform: translateX(0) scale(1);
    pointer-events: auto;
  }

  .page-slide:not(.active) {
    transform: translateX(-100px) scale(0.9);
  }

  .page-label {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.5rem;
    background: linear-gradient(90deg, rgba(255, 0, 170, 0.1), transparent);
    border-bottom: 1px solid var(--glass-border);
  }

  .page-number {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: var(--accent-gradient);
    color: var(--bg-primary);
    font-weight: 700;
    font-size: 1rem;
    border-radius: 50%;
    box-shadow: 0 4px 15px rgba(0, 212, 255, 0.4);
  }

  .page-title {
    font-family: var(--font-heading);
    font-weight: 600;
    color: var(--text-primary);
    font-size: 1.1rem;
  }

  .canvas-wrapper {
    padding: 1rem;
    display: flex;
    justify-content: center;
    background: var(--bg-secondary);
    max-height: calc(100vh - 220px);
    overflow: hidden;
  }

  .canvas-wrapper canvas {
    max-width: 100%;
    max-height: calc(100vh - 260px);
    object-fit: contain;
    border-radius: var(--radius-sm);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
  }

  .loading-state {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    color: var(--text-secondary);
    font-size: 0.95rem;
    transition: opacity 0.5s ease;
  }

  .loading-state.hidden {
    opacity: 0;
    pointer-events: none;
  }

  .wave-text {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 500;
    color: var(--text-muted);
    margin-top: 1.5rem;
  }

  .dots-container {
    display: flex;
    justify-content: center;
    gap: 0.75rem;
    padding: 1rem;
    flex-shrink: 0;
  }

  .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--glass-border);
    border: none;
    cursor: pointer;
    transition: all var(--transition-normal);
  }

  .dot:hover {
    background: rgba(255, 0, 170, 0.5);
    transform: scale(1.2);
  }

  .dot.active {
    background: var(--accent-magenta);
    box-shadow: 0 0 15px rgba(255, 0, 170, 0.6);
    transform: scale(1.3);
  }

  .floating-shapes {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: -1;
    overflow: hidden;
  }

  .shape {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.15;
  }

  .shape-1 {
    width: 400px;
    height: 400px;
    background: var(--accent-cyan);
    top: -100px;
    left: -100px;
    animation: floatShape 20s ease-in-out infinite;
  }

  .shape-2 {
    width: 300px;
    height: 300px;
    background: var(--accent-magenta);
    bottom: -50px;
    right: -50px;
    animation: floatShape 15s ease-in-out infinite reverse;
  }

  .shape-3 {
    width: 200px;
    height: 200px;
    background: linear-gradient(135deg, var(--accent-cyan), var(--accent-magenta));
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    animation: floatShape 25s ease-in-out infinite;
  }

  @keyframes floatShape {
    0%, 100% { transform: translate(0, 0) rotate(0deg); }
    25% { transform: translate(50px, -50px) rotate(90deg); }
    50% { transform: translate(0, -100px) rotate(180deg); }
    75% { transform: translate(-50px, -50px) rotate(270deg); }
  }

  @media (max-width: 768px) {
    .carousel-container { padding: 1rem; gap: 0.5rem; }
    .nav-btn { width: 40px; height: 40px; }
    .page-label { padding: 0.75rem 1rem; }
    .page-number { width: 30px; height: 30px; font-size: 0.9rem; }
    .page-title { font-size: 0.95rem; }
  }
</style>
