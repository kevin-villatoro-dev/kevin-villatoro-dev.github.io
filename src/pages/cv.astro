---
import Layout from '../layouts/Layout.astro';
---

<Layout title="CV - Kevin Villatoro">
  <div class="cv-viewer">
    <div class="header-bar">
      <a href="/" class="back-link">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        Volver
      </a>
      <h1 class="title">Curriculum Vitae</h1>
      <div class="download-btn">
        <a href="/kevin_villatoro_cv.pdf" download class="btn-download" id="download-btn">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          <span class="btn-text">Descargar</span>
          <span class="btn-check">✓</span>
        </a>
      </div>
    </div>
    
    <div class="pdf-showcase">
      <div class="glow-border">
        <div class="pdf-container">
          <canvas id="pdf-canvas"></canvas>
          <div class="loading-overlay" id="loading">
            <div class="wave-loader">
              <div class="wave-bar"></div>
              <div class="wave-bar"></div>
              <div class="wave-bar"></div>
              <div class="wave-bar"></div>
              <div class="wave-bar"></div>
            </div>
            <span>Cargando CV...</span>
          </div>
        </div>
      </div>
    </div>

    <div class="bg-particles">
      <div class="particle"></div>
      <div class="particle"></div>
      <div class="particle"></div>
    </div>
  </div>

  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js" define:vars={{}}></script>
  <script is:inline>
    pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';
    
    async function renderPDF(url) {
      try {
        const pdf = await pdfjsLib.getDocument(url).promise;
        const page = await pdf.getPage(1);
        const scale = 2.2;
        const viewport = page.getViewport({ scale });
        
        const canvas = document.getElementById('pdf-canvas');
        const context = canvas.getContext('2d');
        canvas.height = viewport.height;
        canvas.width = viewport.width;
        
        await page.render({ canvasContext: context, viewport }).promise;
        
        const loading = document.getElementById('loading');
        loading.classList.add('hidden');
        canvas.classList.add('revealed');
      } catch (error) {
        console.error('Error loading PDF:', error);
      }
    }
    
    renderPDF('/kevin_villatoro_cv.pdf');
    
    // Download button animation
    const downloadBtn = document.getElementById('download-btn');
    downloadBtn.addEventListener('click', function(e) {
      const viewer = document.querySelector('.cv-viewer');
      
      // Add ripple effect
      const ripple = document.createElement('span');
      ripple.className = 'ripple';
      this.appendChild(ripple);
      
      // Add downloading state
      this.classList.add('downloading');
      
      // Add page animation
      viewer.classList.add('download-flash');
      
      // Remove animation after completion
      setTimeout(() => {
        this.classList.remove('downloading');
        this.classList.add('downloaded');
        ripple.remove();
        
        // Reset after 2 seconds
        setTimeout(() => {
          this.classList.remove('downloaded');
          viewer.classList.remove('download-flash');
        }, 2000);
      }, 1000);
    });
  </script>
</Layout>

<style>
  .cv-viewer {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    background: var(--bg-primary);
    position: relative;
    overflow: hidden;
  }

  .header-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 2rem;
    background: rgba(10, 10, 15, 0.9);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--glass-border);
    z-index: 10;
    animation: slideDown 0.6s ease-out;
    flex-shrink: 0;
  }

  @supports not (backdrop-filter: blur(1px)) {
    .header-bar {
      background: rgba(10, 10, 15, 0.98);
    }
  }

  @keyframes slideDown {
    from { transform: translateY(-100%); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
  }

  .back-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-secondary);
    text-decoration: none;
    font-weight: 500;
    padding: 0.5rem 1rem;
    border-radius: var(--radius-full);
    transition: color 0.3s ease, border-color 0.3s ease, background 0.3s ease, transform 0.3s ease;
    border: 1px solid transparent;
  }

  .back-link:hover {
    color: var(--accent-cyan);
    border-color: var(--accent-cyan);
    background: rgba(0, 212, 255, 0.1);
    transform: translateX(-5px);
  }

  .title {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 600;
    background: var(--accent-gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: glowText 3s ease-in-out infinite;
  }

  @keyframes glowText {
    0%, 100% { filter: drop-shadow(0 0 8px rgba(0, 212, 255, 0.25)); }
    50% { filter: drop-shadow(0 0 12px rgba(255, 0, 170, 0.35)); }
  }

  .btn-download {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 1.2rem;
    background: var(--accent-gradient);
    color: var(--bg-primary);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.9rem;
    border-radius: var(--radius-full);
    transition: box-shadow 0.3s ease;
    box-shadow: 0 4px 15px rgba(0, 212, 255, 0.3);
    position: relative;
    overflow: hidden;
    animation: bounceScale 2s ease-in-out infinite;
  }

  @keyframes bounceScale {
    0%, 100% { transform: scale(1); }
    30% { transform: scale(1.08); }
    50% { transform: scale(0.95); }
    70% { transform: scale(1.04); }
  }

  .btn-download:hover {
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.4);
    animation: none;
    transform: scale(1.08);
  }

  .btn-download:active {
    transform: scale(0.98);
  }

  .btn-download.downloading {
    pointer-events: none;
    background: linear-gradient(135deg, var(--accent-cyan), var(--accent-cyan));
    animation: btnPulse 0.6s ease-in-out infinite;
  }

  .btn-download.downloaded {
    background: linear-gradient(135deg, #00ff88, #00d4ff);
    animation: btnSuccess 0.4s ease-out;
  }

  .btn-download .btn-check {
    display: none;
  }

  .btn-download.downloaded .btn-text,
  .btn-download.downloaded svg {
    display: none;
  }

  .btn-download.downloaded .btn-check {
    display: inline;
    font-size: 1.2rem;
    animation: checkPop 0.3s ease-out;
  }

  @keyframes btnPulse {
    0%, 100% { box-shadow: 0 4px 15px rgba(0, 212, 255, 0.3); }
    50% { box-shadow: 0 4px 25px rgba(0, 212, 255, 0.5), 0 0 35px rgba(255, 0, 170, 0.2); }
  }

  @keyframes btnSuccess {
    0% { transform: scale(1); }
    50% { transform: scale(1.1); }
    100% { transform: scale(1); }
  }

  @keyframes checkPop {
    0% { transform: scale(0); }
    50% { transform: scale(1.3); }
    100% { transform: scale(1); }
  }

  .ripple {
    position: absolute;
    width: 100%;
    height: 100%;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.6) 0%, transparent 70%);
    transform: scale(0);
    animation: rippleEffect 0.6s ease-out;
    pointer-events: none;
  }

  @keyframes rippleEffect {
    to {
      transform: scale(4);
      opacity: 0;
    }
  }

  .cv-viewer.download-flash::after {
    content: '';
    position: fixed;
    inset: 0;
    background: radial-gradient(circle at center, rgba(0, 212, 255, 0.15), transparent 70%);
    animation: flashEffect 1s ease-out forwards;
    pointer-events: none;
    z-index: 100;
  }

  @keyframes flashEffect {
    0% { opacity: 1; transform: scale(0.8); }
    50% { opacity: 1; transform: scale(1.2); }
    100% { opacity: 0; transform: scale(1.5); }
  }

  .pdf-showcase {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    animation: fadeInUp 0.8s ease-out 0.3s both;
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .glow-border {
    position: relative;
    padding: 0;
  }

  .pdf-container {
    position: relative;
    background: var(--bg-secondary);
    border-radius: calc(var(--radius-lg) - 3px);
    overflow: hidden;
    box-shadow: var(--glass-shadow);
  }

  #pdf-canvas {
    display: block;
    max-width: 85vw;
    max-height: 88vh;
    opacity: 0;
    transform: scale(0.95);
    transition: all 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  }

  #pdf-canvas.revealed {
    opacity: 1;
    transform: scale(1);
  }

  .loading-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    background: var(--bg-secondary);
    color: var(--text-secondary);
    font-size: 0.9rem;
    transition: opacity 0.4s ease;
  }

  .loading-overlay.hidden {
    opacity: 0;
    pointer-events: none;
  }

  .wave-loader {
    display: flex;
    align-items: center;
    gap: 6px;
    height: 50px;
  }

  .wave-bar {
    width: 8px;
    height: 20px;
    border-radius: 4px;
    animation: wave 1.2s ease-in-out infinite;
  }

  .wave-bar:nth-child(1) {
    background: var(--accent-cyan);
    animation-delay: 0s;
  }
  .wave-bar:nth-child(2) {
    background: #00b8d9;
    animation-delay: 0.1s;
  }
  .wave-bar:nth-child(3) {
    background: #a855f7;
    animation-delay: 0.2s;
  }
  .wave-bar:nth-child(4) {
    background: #d946ef;
    animation-delay: 0.3s;
  }
  .wave-bar:nth-child(5) {
    background: var(--accent-magenta);
    animation-delay: 0.4s;
  }

  @keyframes wave {
    0%, 100% { height: 20px; opacity: 0.6; }
    50% { height: 45px; opacity: 1; }
  }

  .bg-particles {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: -1;
    contain: layout style paint;
  }

  .particle {
    position: absolute;
    width: 3px;
    height: 3px;
    background: var(--accent-cyan);
    border-radius: 50%;
    opacity: 0.2;
    animation: floatParticle 15s infinite linear;
    will-change: transform;
  }

  .particle:nth-child(1) { left: 10%; animation-delay: 0s; animation-duration: 12s; }
  .particle:nth-child(2) { left: 50%; animation-delay: 3s; animation-duration: 16s; background: var(--accent-magenta); }
  .particle:nth-child(3) { left: 85%; animation-delay: 6s; animation-duration: 20s; }

  @keyframes floatParticle {
    0% { transform: translateY(100vh) rotate(0deg); opacity: 0; }
    10% { opacity: 0.3; }
    90% { opacity: 0.3; }
    100% { transform: translateY(-100vh) rotate(720deg); opacity: 0; }
  }

  @media (max-width: 768px) {
    .header-bar {
      padding: 1rem;
      flex-wrap: wrap;
      gap: 1rem;
    }
    .title { font-size: 1.1rem; }
    #pdf-canvas { max-width: 95vw; }
    .glow-border { margin: 0.5rem; }
  }
</style>
