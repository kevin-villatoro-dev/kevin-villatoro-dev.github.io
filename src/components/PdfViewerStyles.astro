<style is:global>
	.pdf-header-bar {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 1rem 2rem;
		background: rgba(10, 10, 15, 0.9);
		backdrop-filter: blur(12px);
		border-bottom: 1px solid var(--glass-border);
		z-index: 10;
		flex-shrink: 0;
	}

	@supports not (backdrop-filter: blur(1px)) {
		.pdf-header-bar {
			background: rgba(10, 10, 15, 0.98);
		}
	}

	.pdf-back-link {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		color: var(--text-secondary);
		text-decoration: none;
		font-weight: 500;
		padding: 0.5rem 1rem;
		border-radius: var(--radius-full);
		transition: color 0.3s ease, border-color 0.3s ease, background 0.3s ease, transform 0.3s ease;
		border: 1px solid transparent;
	}

	.pdf-back-link:hover {
		color: var(--accent-cyan);
		border-color: var(--accent-cyan);
		background: rgba(0, 212, 255, 0.1);
		transform: translateX(-5px);
	}

	.pdf-title {
		font-family: var(--font-heading);
		font-size: 1.5rem;
		font-weight: 600;
		background: var(--accent-gradient);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.pdf-wave-loader {
		display: flex;
		align-items: center;
		gap: 6px;
		height: 50px;
	}

	.pdf-wave-bar {
		width: 8px;
		height: 20px;
		border-radius: 4px;
		animation: pdfWave 1.2s ease-in-out infinite;
	}

	.pdf-wave-bar:nth-child(1) {
		background: var(--accent-cyan);
		animation-delay: 0s;
	}
	.pdf-wave-bar:nth-child(2) {
		background: var(--accent-cyan);
		animation-delay: 0.1s;
	}
	.pdf-wave-bar:nth-child(3) {
		background: var(--accent-purple);
		animation-delay: 0.2s;
	}
	.pdf-wave-bar:nth-child(4) {
		background: var(--accent-magenta);
		animation-delay: 0.3s;
	}
	.pdf-wave-bar:nth-child(5) {
		background: var(--accent-magenta);
		animation-delay: 0.4s;
	}

	@keyframes pdfWave {
		0%, 100% { height: 20px; opacity: 0.6; }
		50% { height: 45px; opacity: 1; }
	}

	@media (max-width: 768px) {
		.pdf-header-bar {
			padding: 1rem;
			flex-wrap: wrap;
			gap: 1rem;
		}
		.pdf-title { font-size: 1.1rem; }
	}
</style>
