<script>
	document.querySelectorAll(".social-copy").forEach((btn) => {
		btn.addEventListener("click", (e) => {
			e.preventDefault();
			e.stopPropagation();
			const textToCopy = btn.getAttribute("data-copy") || "";
			navigator.clipboard.writeText(textToCopy).then(() => {
				btn.classList.add("copied");
				setTimeout(() => btn.classList.remove("copied"), 2000);
			});
		});
	});
</script>

<style>
	.contact {
		overflow: hidden;
	}

	.social-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 1.5rem;
		max-width: 1000px;
		margin: 0 auto;
	}

	/* ── Card ── */
	.social-card {
		position: relative;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1rem;
		padding: 2.5rem 1.5rem 2rem;
		background: var(--glass-bg);
		border: 1px solid var(--glass-border);
		border-radius: var(--radius-lg);
		text-decoration: none;
		touch-action: manipulation;
		overflow: hidden;
		transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.4s cubic-bezier(0.22, 1, 0.36, 1);
	}

	.social-card::before {
		content: "";
		position: absolute;
		inset: 0;
		border-radius: var(--radius-lg);
		padding: 1px;
		background: conic-gradient(
			from var(--card-angle, 0deg),
			transparent 0%,
			transparent 25%,
			var(--card-color, var(--accent-cyan)) 50%,
			transparent 75%,
			transparent 100%
		);
		-webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
		mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
		-webkit-mask-composite: xor;
		mask-composite: exclude;
		opacity: 0;
		transition: opacity 0.4s ease;
	}

	.social-card:hover::before {
		opacity: 1;
		animation: borderRotate 3s linear infinite;
	}

	@keyframes borderRotate {
		to { --card-angle: 360deg; }
	}

	@property --card-angle {
		syntax: "<angle>";
		initial-value: 0deg;
		inherits: false;
	}

	.social-card:hover {
		transform: translateY(-6px);
		box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
	}

	.social-card:focus-visible {
		outline: 2px solid var(--accent-cyan);
		outline-offset: 2px;
	}

	/* ── Glow (behind icon) ── */
	.social-glow {
		position: absolute;
		top: 1.25rem;
		width: 80px;
		height: 80px;
		border-radius: 50%;
		filter: blur(30px);
		opacity: 0;
		transition: opacity 0.4s ease;
		pointer-events: none;
	}

	.social-card:hover .social-glow {
		opacity: 0.5;
	}

	.social-glow-email { background: #ea4335; }
	.social-glow-linkedin { background: #0a66c2; }
	.social-glow-github { background: #f0f0f0; }
	.social-glow-whatsapp { background: #25d366; }

	/* ── Icon ring ── */
	.social-ring {
		position: relative;
		z-index: 1;
		width: 64px;
		height: 64px;
		display: flex;
		align-items: center;
		justify-content: center;
		border-radius: 50%;
		border: 2px solid var(--glass-border);
		transition: border-color 0.3s ease, transform 0.4s cubic-bezier(0.22, 1, 0.36, 1);
	}

	.social-card:hover .social-ring {
		transform: scale(1.1);
	}

	.social-ring-email { color: #ea4335; }
	.social-ring-linkedin { color: #0a66c2; }
	.social-ring-github { color: #f0f0f0; }
	.social-ring-whatsapp { color: #25d366; }

	.social-card:hover .social-ring-email { border-color: #ea4335; }
	.social-card:hover .social-ring-linkedin { border-color: #0a66c2; }
	.social-card:hover .social-ring-github { border-color: #f0f0f0; }
	.social-card:hover .social-ring-whatsapp { border-color: #25d366; }

	/* ── Label ── */
	.social-label {
		position: relative;
		z-index: 1;
		font-size: 1rem;
		font-weight: 600;
		color: var(--text-primary);
		letter-spacing: 0.02em;
	}

	/* ── Copy button ── */
	.social-copy {
		position: absolute;
		top: 0.75rem;
		right: 0.75rem;
		z-index: 2;
		display: flex;
		align-items: center;
		justify-content: center;
		width: 32px;
		height: 32px;
		background: rgba(255, 255, 255, 0.05);
		border: 1px solid var(--glass-border);
		border-radius: var(--radius-sm);
		color: var(--text-muted);
		cursor: pointer;
		opacity: 0;
		touch-action: manipulation;
		transition: opacity 0.2s ease, background 0.2s ease, color 0.2s ease, border-color 0.2s ease;
	}

	.social-card:hover .social-copy,
	.social-card:focus-within .social-copy {
		opacity: 1;
	}

	@media (hover: none) {
		.social-copy {
			opacity: 1;
		}
	}

	.social-copy:hover {
		background: rgba(0, 212, 255, 0.12);
		color: var(--accent-cyan);
		border-color: rgba(0, 212, 255, 0.3);
	}

	.social-copy:focus-visible {
		outline: 2px solid var(--accent-cyan);
		outline-offset: 1px;
	}

	.social-copy .icon-check { display: none; }
	.social-copy.copied .icon-copy { display: none; }
	.social-copy.copied .icon-check { display: block; color: #25d366; }
	.social-copy.copied {
		background: rgba(37, 211, 102, 0.12);
		border-color: rgba(37, 211, 102, 0.3);
	}

	/* ── Responsive ── */
	@media (max-width: 968px) {
		.social-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 480px) {
		.social-grid {
			grid-template-columns: 1fr;
			max-width: 320px;
		}

		.social-card {
			padding: 2rem 1.25rem 1.75rem;
		}
	}
</style>
