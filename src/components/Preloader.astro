---

---

<div class="preloader" id="preloader">
	<div class="preloader-bg"></div>
	<div class="preloader-content">
		<div class="terminal">
			<div class="terminal-header">
				<div class="terminal-dots">
					<span class="dot-t dot-red"></span>
					<span class="dot-t dot-yellow"></span>
					<span class="dot-t dot-green"></span>
				</div>
				<span class="terminal-title">portfolio@build</span>
			</div>
			<div class="terminal-body">
				<div class="terminal-line">
					<span class="terminal-prompt">$</span>
					<span class="terminal-command" id="cmd-1">npm run build</span>
				</div>
				<div class="terminal-line output-line" id="out-1">
					<span class="terminal-output"> Compilando portafolio...</span>
				</div>
				<div class="terminal-line output-line" id="out-2">
					<span class="terminal-output success"> ✓ Componentes cargados</span>
				</div>
				<div class="terminal-line output-line" id="out-3">
					<span class="terminal-output success"> ✓ Secciones renderizadas</span>
				</div>
				<div class="terminal-line output-line" id="out-4">
					<span class="terminal-output success"> ✓ Experiencia verificada</span>
				</div>
				<div class="terminal-line output-line" id="out-5">
					<span class="terminal-output success"> ✓ Proyectos listos</span>
				</div>
				<div class="terminal-line output-line" id="out-6">
					<span class="terminal-output final"> 🚀 Portafolio desplegado</span>
				</div>
			</div>
		</div>

		<div class="loader-bar-container">
			<div class="loader-bar">
				<div class="loader-bar-fill" id="loader-fill"></div>
			</div>
			<span class="loader-percent" id="loader-percent">0%</span>
		</div>

		<div class="code-rain" aria-hidden="true">
			<div class="rain-column" style="--delay: 0s; --x: 5%"></div>
			<div class="rain-column" style="--delay: 0.5s; --x: 12%"></div>
			<div class="rain-column" style="--delay: 1s; --x: 20%"></div>
			<div class="rain-column" style="--delay: 1.5s; --x: 28%"></div>
			<div class="rain-column" style="--delay: 0.3s; --x: 35%"></div>
			<div class="rain-column" style="--delay: 0.8s; --x: 42%"></div>
			<div class="rain-column" style="--delay: 1.2s; --x: 50%"></div>
			<div class="rain-column" style="--delay: 0.6s; --x: 58%"></div>
			<div class="rain-column" style="--delay: 1.8s; --x: 65%"></div>
			<div class="rain-column" style="--delay: 0.2s; --x: 72%"></div>
			<div class="rain-column" style="--delay: 1.1s; --x: 80%"></div>
			<div class="rain-column" style="--delay: 0.9s; --x: 88%"></div>
			<div class="rain-column" style="--delay: 1.4s; --x: 95%"></div>
		</div>

		<div class="particles-preloader" aria-hidden="true">
			<div class="particle-p"></div>
			<div class="particle-p"></div>
			<div class="particle-p"></div>
			<div class="particle-p"></div>
			<div class="particle-p"></div>
			<div class="particle-p"></div>
		</div>
	</div>
</div>

<style>
	.preloader {
		position: fixed;
		inset: 0;
		z-index: 9999;
		display: flex;
		align-items: center;
		justify-content: center;
		transition: opacity 0.6s ease, visibility 0.6s ease;
	}

	.preloader.hidden {
		opacity: 0;
		visibility: hidden;
		pointer-events: none;
	}

	.preloader-bg {
		position: absolute;
		inset: 0;
		background: var(--bg-primary);
	}

	.preloader-content {
		position: relative;
		z-index: 1;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 2rem;
	}

	/* ── Terminal ── */
	.terminal {
		width: 380px;
		background: rgba(15, 15, 25, 0.95);
		border: 1px solid rgba(0, 212, 255, 0.2);
		border-radius: 12px;
		overflow: hidden;
		box-shadow:
			0 0 40px rgba(0, 212, 255, 0.1),
			0 20px 60px rgba(0, 0, 0, 0.5);
		animation: terminalAppear 0.6s cubic-bezier(0.22, 1, 0.36, 1) forwards;
	}

	@keyframes terminalAppear {
		from {
			opacity: 0;
			transform: translateY(20px) scale(0.95);
		}
		to {
			opacity: 1;
			transform: translateY(0) scale(1);
		}
	}

	.terminal-header {
		display: flex;
		align-items: center;
		gap: 1rem;
		padding: 0.75rem 1rem;
		background: rgba(0, 0, 0, 0.4);
		border-bottom: 1px solid rgba(255, 255, 255, 0.06);
	}

	.terminal-dots {
		display: flex;
		gap: 6px;
	}

	.dot-t {
		width: 10px;
		height: 10px;
		border-radius: 50%;
	}

	.dot-red { background: #ff5f57; }
	.dot-yellow { background: #ffbd2e; }
	.dot-green { background: #28c840; }

	.terminal-title {
		font-family: "SF Mono", "Fira Code", monospace;
		font-size: 0.75rem;
		color: var(--text-muted);
	}

	.terminal-body {
		padding: 1.25rem;
		min-height: 200px;
	}

	.terminal-line {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		margin-bottom: 0.5rem;
		font-family: "SF Mono", "Fira Code", monospace;
		font-size: 0.8rem;
		line-height: 1.6;
	}

	.terminal-prompt {
		color: var(--accent-cyan);
		font-weight: 600;
	}

	.terminal-command {
		color: var(--text-primary);
	}

	.output-line {
		opacity: 0;
		transform: translateX(-10px);
	}

	.output-line.visible {
		opacity: 1;
		transform: translateX(0);
		transition: opacity 0.3s ease, transform 0.3s ease;
	}

	.terminal-output {
		color: var(--text-secondary);
	}

	.terminal-output.success {
		color: #34d399;
	}

	.terminal-output.final {
		color: var(--accent-cyan);
		font-weight: 600;
	}

	/* ── Loader Bar ── */
	.loader-bar-container {
		display: flex;
		align-items: center;
		gap: 1rem;
		width: 380px;
	}

	.loader-bar {
		flex: 1;
		height: 4px;
		background: rgba(255, 255, 255, 0.06);
		border-radius: 2px;
		overflow: hidden;
	}

	.loader-bar-fill {
		width: 0%;
		height: 100%;
		background: var(--accent-gradient);
		border-radius: 2px;
		transition: width 0.3s ease;
		box-shadow: 0 0 12px rgba(0, 212, 255, 0.4);
	}

	.loader-percent {
		font-family: "SF Mono", "Fira Code", monospace;
		font-size: 0.8rem;
		color: var(--accent-cyan);
		font-weight: 600;
		min-width: 36px;
		text-align: right;
	}

	/* ── Code Rain ── */
	.code-rain {
		position: fixed;
		inset: 0;
		pointer-events: none;
		z-index: 0;
		overflow: hidden;
	}

	.rain-column {
		position: absolute;
		left: var(--x);
		top: -100%;
		width: 1px;
		height: 200%;
		background: linear-gradient(
			180deg,
			transparent 0%,
			rgba(0, 212, 255, 0.15) 20%,
			rgba(0, 212, 255, 0.3) 50%,
			rgba(0, 212, 255, 0.15) 80%,
			transparent 100%
		);
		animation: rainFall 2s linear infinite;
		animation-delay: var(--delay);
	}

	@keyframes rainFall {
		0% {
			transform: translateY(-50%);
		}
		100% {
			transform: translateY(50%);
		}
	}

	/* ── Particles ── */
	.particles-preloader {
		position: fixed;
		inset: 0;
		pointer-events: none;
		z-index: 0;
	}

	.particle-p {
		position: absolute;
		width: 4px;
		height: 4px;
		background: var(--accent-cyan);
		border-radius: 50%;
		opacity: 0;
		animation: particleFloat 4s ease-in-out infinite;
	}

	.particle-p:nth-child(1) { left: 10%; animation-delay: 0s; animation-duration: 3.5s; }
	.particle-p:nth-child(2) { left: 25%; animation-delay: 0.8s; animation-duration: 4.2s; background: var(--accent-magenta); }
	.particle-p:nth-child(3) { left: 45%; animation-delay: 1.5s; animation-duration: 3.8s; }
	.particle-p:nth-child(4) { left: 65%; animation-delay: 0.3s; animation-duration: 4.5s; background: var(--accent-magenta); }
	.particle-p:nth-child(5) { left: 80%; animation-delay: 1.2s; animation-duration: 3.2s; }
	.particle-p:nth-child(6) { left: 92%; animation-delay: 2s; animation-duration: 4s; background: var(--accent-magenta); }

	@keyframes particleFloat {
		0% {
			transform: translateY(100vh) scale(0);
			opacity: 0;
		}
		20% {
			opacity: 0.6;
			transform: translateY(60vh) scale(1);
		}
		80% {
			opacity: 0.6;
		}
		100% {
			transform: translateY(-20vh) scale(0);
			opacity: 0;
		}
	}

	/* ── Responsive ── */
	@media (max-width: 480px) {
		.terminal {
			width: 320px;
		}
		.loader-bar-container {
			width: 320px;
		}
		.terminal-body {
			min-height: 180px;
		}
		.terminal-line {
			font-size: 0.7rem;
		}
	}
</style>

<script is:inline>
	const preloader = document.getElementById("preloader");
	const fill = document.getElementById("loader-fill");
	const percent = document.getElementById("loader-percent");

	const lines = [
		"out-1",
		"out-2",
		"out-3",
		"out-4",
		"out-5",
		"out-6",
	];

	const percents = [15, 35, 55, 75, 90, 100];

	lines.forEach((id, i) => {
		const el = document.getElementById(id);
		if (!el) return;
		setTimeout(() => {
			el.classList.add("visible");
			fill.style.width = percents[i] + "%";
			percent.textContent = percents[i] + "%";
		}, 400 + i * 350);
	});

	const totalDuration = 400 + lines.length * 350 + 600;

	setTimeout(() => {
		preloader.classList.add("hidden");
		document.body.style.overflow = "";
	}, totalDuration);

	document.body.style.overflow = "hidden";
</script>
