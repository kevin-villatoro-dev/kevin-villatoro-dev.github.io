---
import ProjectCard from "./ProjectCard.astro"

const projects = [
	{
		title: "Ecosistema Fintech MultiTenant",
		description:
			"Software que facilita la venta en línea sin necesidad de contar con un sitio web. La comodidad de pagar a distancia o a través de tus redes sociales con sus tarjetas Visa, Mastercard o utilizando sus billeteras digitales. Crea, comparte y recibe tus pagos.",
		tags: [
			"PHP",
			"Javascript",
			"Composer",
			"Bootstrap",
			"MySQL",
			"Git",
			"Payment Gateways",
			"Digital Wallets",
			"DTE/FEL",
			"SMS",
			"Dashboards",
			"Notificaciones",
		],
		images: [
			"/images/projects/hosted-checkout-v1-adm.svg",
			"/images/projects/hosted-checkout-v1-checkout.svg",
			"/images/projects/hosted-checkout-v2-checkout.svg",
		],
		featured: true,
		confidential: true,
	},
	{
		title: "Ecommerce / Shopping Cart",
		description:
			"App de ecommerce en monorepo con Turborepo: storefront en React 19 + Vite + Tailwind CSS, backend en Fastify + Drizzle + PostgreSQL, y panel admin en Laravel 11. Incluye catálogo de productos, carrito persistido en localStorage, checkout con JWT, y gestión de órdenes.",
		tags: ["Laravel", "React", "PostgreSQL", "Vite", "Nginx", "Tailwind CSS", "Docker", "pnpm", "Turborepo"],
		image: "/images/projects/ecommerce-demo.svg",
		github: "https://github.com/kevin-villatoro-dev/carro-de-compras",
	},
	{
		title: "Sistema de Finanzas",
		description:
			"Panel de control financiero. Control de ingresos, egresos, balance general, recordatorios y notificaciones por correo.",
		tags: ["PHP", "JavaScript", "MySQL", "Composer", "Git", "Bootstrap"],
		image: "/images/projects/finanzas-demo.svg",
		confidential: true,
	},
	{
		title: "API Gateway",
		description:
			"Gateway centralizado para orquestar múltiples microservicios con dashboard para visualizar el tráfico de las peticiones.",
		tags: ["React", "Fastify", "Typescript", "JWT"],
		image: "/images/projects/api-gateway-demo.svg",
		github: "https://github.com/kevin-villatoro-dev/api-gateway",
	},
]

const featuredProjects = projects.filter((p) => p.featured)
const otherProjects = projects.filter((p) => !p.featured)
---

<section id="proyectos" class="projects section">
	<div class="container">
		<div class="section-title">
			<h2>Proyectos <span class="gradient-text">destacados</span></h2>
			<p>Una selección de proyectos que demuestra la forma en que resuelvo problemas reales y reflejan mi experiencia</p>
		</div>

		<div class="projects-hero-grid">
			{featuredProjects.map((project) => <ProjectCard {...project} layout="hero" />)}
		</div>

		{
			otherProjects.length > 0 && (
				<div class="projects-compact-grid">
					{otherProjects.map((project) => (
						<ProjectCard {...project} layout="compact" />
					))}
				</div>
			)
		}
		<div class="section-cta">
			<a href="#contacto" aria-label="Ir a contacto">
				<svg
					xmlns="http://www.w3.org/2000/svg"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-linecap="round"
					stroke-linejoin="round"
					aria-hidden="true"><path d="m6 9 6 6 6-6"></path></svg
				>
			</a>
		</div>
	</div>
</section>

<style>
	/* ── Hero grid: full-width horizontal cards ── */
	.projects-hero-grid {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
		margin-bottom: 2rem;
	}

	/* ── Compact grid: smaller cards below ── */
	.projects-compact-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.5rem;
	}

	@media (max-width: 1024px) {
		.projects-compact-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 768px) {
		.projects-compact-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
