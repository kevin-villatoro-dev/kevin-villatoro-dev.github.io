---
import ProjectCard from "./ProjectCard.astro"

const projects = [
	{
		title: "Ecosistema Fintech MultiTenant",
		description:
			"Facilita la venta en línea sin necesidad de contar con un sitio web. Ofrece a tus clientes la comodidad de pagar a distancia o a través de tus redes sociales con sus tarjetas Visa, Mastercard o utilizando sus billeteras digitales, generando un link de pago personalizado. Crea, comparte y recibe tus pagos.",
		tags: [
			"PHP",
			"Javascript",
			"MySQL",
			"Composer",
			"Git",
			"Payment Gateways",
			"Wallets",
			"DTE/FEL",
			"SMS",
			"Dashboards",
			"Notificaciones",
		],
		images: [
			"/images/projects/hosted-checkout-v1-adm.svg",
			"/images/projects/hosted-checkout-v1-checkout.svg",
			"/images/projects/hosted-checkout-v2-adm.svg",
			"/images/projects/hosted-checkout-v2-checkout.svg",
		],
		featured: true,
		confidential: true,
	},
	{
		title: "Ecommerce",
		description:
			"Plataforma de comercio electrónico con arquitectura MVC. Carrito de compras en tiempo real, pasarela de pagos integrada y panel de administración para gestión de inventario, pedidos y reportes de ventas.",
		tags: ["Laravel", "React", "PostgreSQL", "Vite", "REST", "Docker"],
		image: "/images/projects/ecommerce-demo.svg",
		github: "https://github.com/kevin-villatoro-dev/",
	},
	{
		title: "Sistema de Finanzas",
		description:
			"Panel de control financiero. Control de ingresos, egresos, balance general, recordatorios y notificaciones por correo.",
		tags: ["PHP", "JavaScript", "MySQL", "Composer", "Git", "Bootstrap"],
		image: "/images/projects/finanzas-demo.svg",
		github: "https://github.com/kevin-villatoro-dev/",
		confidential: true,
	},
	{
		title: "API Gateway Modular",
		description:
			"Gateway centralizado para orquestar múltiples microservicios. Enrutamiento, autenticación, rate limiting y balanceo de carga con arquitectura modular y extensible.",
		tags: ["Docker", "REST"],
		image: "/images/projects/api-gateway-demo.svg",
		github: "https://github.com/kevin-villatoro-dev/",
	},
]

const featuredProjects = projects.filter((p) => p.featured)
const otherProjects = projects.filter((p) => !p.featured)
---

<section id="proyectos" class="projects section">
	<div class="container">
		<div class="section-title">
			<h2>Proyectos <span class="gradient-text">Destacados</span></h2>
			<p>Una selección de trabajos que reflejan mi experiencia y pasión</p>
		</div>

		<div class="projects-hero-grid">
			{featuredProjects.map((project) => <ProjectCard {...project} layout="hero" />)}
		</div>

		{
			otherProjects.length > 0 && (
				<div class="projects-compact-grid">
					{otherProjects.map((project) => (
						<ProjectCard {...project} layout="compact" />
					))}
				</div>
			)
		}
	</div>
</section>

<style>
	/* ── Hero grid: full-width horizontal cards ── */
	.projects-hero-grid {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
		margin-bottom: 2rem;
	}

	/* ── Compact grid: smaller cards below ── */
	.projects-compact-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.5rem;
	}

	@media (max-width: 1024px) {
		.projects-compact-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 768px) {
		.projects-compact-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
