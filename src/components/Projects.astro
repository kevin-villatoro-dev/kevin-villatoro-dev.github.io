---
import ProjectCard from "./ProjectCard.astro";

const projects = [
  {
    title: "TaskFlow",
    description: "Plataforma de gestión de proyectos con sistema de equipos, roles y permisos. Incluye tablero Kanban, time tracking y reportes en tiempo real.",
    tags: ["React", "Node.js", "PostgreSQL", "WebSocket"],
    github: "https://github.com/alejandrom/taskflow",
    demo: "https://taskflow-demo.vercel.app",
    featured: true,
  },
  {
    title: "CryptoTracker",
    description: "Dashboard de criptomonedas con datos en tiempo real, gráficos interactivos y alertas de precio personalizables.",
    tags: ["Next.js", "TypeScript", "Chart.js", "CoinGecko API"],
    github: "https://github.com/alejandrom/cryptotracker",
    demo: "https://cryptotracker-psi.vercel.app",
  },
  {
    title: "DevBlog",
    description: "Blog de tecnología con sistema de publicaciones MDX, búsqueda full-text y newsletter integrado.",
    tags: ["Astro", "MDX", "Tailwind", "Algolia"],
    github: "https://github.com/alejandrom/devblog",
    demo: "https://devblog.dev",
  },
  {
    title: "WeatherApp",
    description: "App del clima con pronóstico de 7 días, ubicación GPS y alertas meteorológicas por región.",
    tags: ["Vue.js", "OpenWeather API", "PWA", "Chart.js"],
    github: "https://github.com/alejandrom/weatherapp",
    featured: true,
  },
  {
    title: "API Gateway",
    description: "Gateway microservicios con rate limiting, auth JWT, cache Redis y métricas de Prometheus.",
    tags: ["Go", "Redis", "Docker", "Kubernetes"],
    github: "https://github.com/alejandrom/api-gateway",
  },
  {
    title: "Design System",
    description: "Sistema de diseño completo con +50 componentes documentados, tokens de diseño y modo oscuro.",
    tags: ["React", "Storybook", "TypeScript", "CSS Variables"],
    github: "https://github.com/alejandrom/design-system",
    demo: "https://design-system.example.com",
  },
];
---

<section id="proyectos" class="projects section">
  <div class="container">
    <div class="section-title">
      <h2>Proyectos <span class="gradient-text">Destacados</span></h2>
      <p>Una selección de trabajos que reflejan mi experiencia y pasión</p>
    </div>
    <div class="projects-grid">
      {projects.map((project) => <ProjectCard {...project} />)}
    </div>
  </div>
</section>

<style>
  .projects { background: var(--bg-secondary); }
  .projects-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(350px, 1fr)); gap: 1.5rem; }
  @media (max-width: 768px) {
    .projects-grid { grid-template-columns: 1fr; }
  }
</style>
