<style>
	.about {
		overflow: hidden;
	}

	.about-grid {
		display: grid;
		grid-template-columns: auto 1fr;
		gap: 4rem;
		align-items: center;
	}

	/* ── Photo ── */
	.about-photo {
		position: relative;
	}

	.photo-wrapper {
		display: flex;
		flex-direction: column;
		align-items: center;
	}

	.photo-frame {
		position: relative;
		padding: 0;
		overflow: visible;
		width: 280px;
		height: 280px;
		transition: transform 0.3s ease;
	}

	.photo-frame:hover {
		transform: scale(1.03);
	}

	.photo-frame::before {
		content: "";
		position: absolute;
		left: 0;
		right: 0;
		height: 2px;
		z-index: 4;
		opacity: 0;
		pointer-events: none;
		background: linear-gradient(90deg, transparent, var(--accent-cyan), var(--accent-magenta), transparent);
	}

	.photo-frame:hover::before {
		animation: scanLine 1.2s ease-in-out infinite;
	}

	@keyframes scanLine {
		0% { top: 0; opacity: 0; }
		10% { opacity: 1; }
		90% { opacity: 1; }
		100% { top: 100%; opacity: 0; }
	}

	.easter-egg-container {
		height: 6rem;
		display: flex;
		align-items: center;
		justify-content: center;
		padding-top: 2rem;
	}

	.easter-egg {
		font-size: 0.9rem;
		font-style: italic;
		color: var(--text-muted);
		text-align: center;
		line-height: 1.5;
		max-width: 280px;
	}

	.easter-egg .cursor {
		display: inline-block;
		width: 2px;
		height: 1em;
		background: var(--accent-cyan);
		margin-left: 2px;
		animation: blink 0.7s step-end infinite;
		vertical-align: text-bottom;
	}

	@keyframes blink {
		50% { opacity: 0; }
	}

	.corner {
		position: absolute;
		width: 32px;
		height: 32px;
		border-style: solid;
		z-index: 3;
		pointer-events: none;
	}

	.corner-tl {
		top: -24px;
		left: -24px;
		border-width: 3px 0 0 3px;
		border-color: var(--accent-cyan);
	}

	.corner-tr {
		top: -24px;
		right: -24px;
		border-width: 3px 3px 0 0;
		border-color: var(--accent-magenta);
	}

	.corner-bl {
		bottom: -24px;
		left: -24px;
		border-width: 0 0 3px 3px;
		border-color: var(--accent-magenta);
	}

	.corner-br {
		bottom: -24px;
		right: -24px;
		border-width: 0 3px 3px 0;
		border-color: var(--accent-cyan);
	}

	.photo-img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.photo-glow {
		position: absolute;
		inset: 0;
		border-radius: var(--radius-lg);
		box-shadow: inset 0 0 60px rgba(0, 212, 255, 0.1);
		pointer-events: none;
	}

	.experience-badge {
		position: absolute;
		bottom: -12px;
		right: -12px;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		width: 80px;
		height: 80px;
		background: var(--accent-gradient);
		border-radius: 50%;
		z-index: 2;
	}

	.exp-number {
