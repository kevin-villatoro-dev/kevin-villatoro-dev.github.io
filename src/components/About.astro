	}

	/* ── Education ── */
	.edu-card {
		display: flex;
		align-items: flex-start;
		gap: 1rem;
		padding: 1.25rem 1.5rem;
		margin-top: 0.5rem;
	}

	.edu-icon {
		flex-shrink: 0;
		display: flex;
		align-items: center;
		justify-content: center;
		width: 40px;
		height: 40px;
		background: rgba(168, 85, 247, 0.1);
		border: 1px solid rgba(168, 85, 247, 0.15);
		border-radius: var(--radius-md);
		color: #a855f7;
	}

	.edu-info {
		flex: 1;
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
		min-width: 0;
	}

	.edu-title {
		font-size: 0.9rem;
		font-weight: 600;
		color: var(--text-primary);
		line-height: 1.3;
	}

	.edu-place {
		font-size: 0.8rem;
		color: var(--accent-magenta);
	}

	.edu-progress {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		margin-top: 0.5rem;
	}

	.edu-progress-bar {
		flex: 1;
		height: 4px;
		background: rgba(255, 255, 255, 0.06);
		border-radius: 2px;
		overflow: hidden;
	}

	.edu-progress-fill {
		width: 42%;
		height: 100%;
		background: var(--accent-gradient);
		border-radius: 2px;
		animation: progressPulse 3s ease-in-out infinite;
	}

	@keyframes progressPulse {
		0%, 100% { opacity: 1; }
		50% { opacity: 0.7; }
	}

	.edu-progress-label {
		font-size: 0.7rem;
		font-weight: 600;
		color: var(--text-muted);
		white-space: nowrap;
	}

	/* ── Responsive ── */
	@media (max-width: 968px) {
		.about-grid {
			grid-template-columns: 1fr;
			gap: 2.5rem;
			text-align: center;
		}

		.about-photo {
			display: flex;
			justify-content: center;
		}

		.photo-frame {
			width: 220px;
			height: 220px;
		}

		.skills-grid {
			grid-template-columns: repeat(3, 1fr);
		}
	}

	@media (max-width: 640px) {
		.skills-grid {
			grid-template-columns: 1fr;
		}

		.photo-frame {
			width: 180px;
			height: 180px;
		}

		.experience-badge {
			width: 60px;
			height: 60px;
			bottom: -6px;
			right: -6px;
		}

		.exp-number {
			font-size: 1.1rem;
		}

		.exp-label {
			font-size: 0.55rem;
		}
	}
</style>
