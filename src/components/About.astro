---

---

<section id="sobre-mi" class="about section">
	<div class="container">
		<div class="section-title">
			<h2>Sobre <span class="gradient-text">mí</span></h2>
			<p>Más allá del código</p>
		</div>

		<div class="about-grid">
			<div class="about-photo">
				<div class="photo-frame glass-card">
					<img src="/profile.png" alt="Kevin Villatoro" class="photo-img" loading="lazy" />
					<div class="photo-glow"></div>
				</div>
				<div class="experience-badge">
					<span class="exp-number">10+</span>
					<span class="exp-label">años</span>
				</div>
			</div>

			<div class="about-content">
				<p class="about-bio">
					Ingeniero de Software con más de 9 años de experiencia liderando el diseño técnico
					y el ciclo completo de despliegue de aplicaciones. Especializado en transformar
					la complejidad técnica en sistemas eficientes, escalables y listos para el futuro.
				</p>
				<p class="about-bio">
					Combino visión estratégica con ejecución práctica: desde la arquitectura de
					microservicios hasta la implementación de metodologías de desarrollo basadas
					en LLMs y Spec-Driven Development.
				</p>

				<div class="soft-skills">
					<div class="skill-card glass-card">
						<div class="skill-icon">
							<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
						</div>
						<h3 class="skill-title">Leadership</h3>
						<p class="skill-desc">Liderazgo técnico y gestión de equipos de desarrollo</p>
					</div>

					<div class="skill-card glass-card">
						<div class="skill-icon">
							<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
						</div>
						<h3 class="skill-title">Problem Solving</h3>
						<p class="skill-desc">Resolución de problemas complejos con enfoque sistemático</p>
					</div>

					<div class="skill-card glass-card">
						<div class="skill-icon">
							<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
						</div>
						<h3 class="skill-title">Communication</h3>
						<p class="skill-desc">Comunicación efectiva con stakeholders técnicos y no técnicos</p>
					</div>
				</div>
		</div>
	</div>
</section>

<style>
	.about {
		overflow: hidden;
	}

	.about-grid {
		display: grid;
		grid-template-columns: auto 1fr;
		gap: 4rem;
		align-items: start;
	}

	/* ── Photo ── */
	.about-photo {
		position: relative;
	}

	.photo-frame {
		position: relative;
		padding: 0;
		overflow: hidden;
		width: 280px;
		height: 280px;
	}

	.photo-img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.photo-glow {
		position: absolute;
		inset: 0;
		border-radius: var(--radius-lg);
		box-shadow: inset 0 0 60px rgba(0, 212, 255, 0.1);
		pointer-events: none;
	}

	.experience-badge {
		position: absolute;
		bottom: -12px;
		right: -12px;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		width: 80px;
		height: 80px;
		background: var(--accent-gradient);
		border-radius: 50%;
		box-shadow: 0 8px 24px rgba(0, 212, 255, 0.3);
		z-index: 2;
	}

	.exp-number {
		font-family: var(--font-heading);
		font-size: 1.5rem;
		font-weight: 700;
		color: var(--bg-primary);
		line-height: 1;
	}

	.exp-label {
		font-size: 0.7rem;
		font-weight: 600;
		color: var(--bg-primary);
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	/* ── Content ── */
	.about-content {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.about-bio {
		font-size: 1.1rem;
		color: var(--text-secondary);
		line-height: 1.8;
	}

	.about-bio:first-child {
		font-size: 1.2rem;
		color: var(--text-primary);
	}

	/* ── Soft Skills ── */
	.soft-skills {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1rem;
		margin-top: 0.5rem;
	}

	.skill-card {
		padding: 1.5rem;
		text-align: center;
		transition: transform 0.3s ease, box-shadow 0.3s ease;
	}

	.skill-card:hover {
		transform: translateY(-4px);
		box-shadow: 0 12px 32px rgba(0, 0, 0, 0.3);
	}

	.skill-icon {
		width: 48px;
		height: 48px;
		display: flex;
		align-items: center;
		justify-content: center;
		margin: 0 auto 1rem;
		background: rgba(0, 212, 255, 0.1);
		border-radius: var(--radius-md);
		color: var(--accent-cyan);
		transition: background 0.3s ease, color 0.3s ease;
	}

	.skill-card:hover .skill-icon {
		background: rgba(0, 212, 255, 0.2);
		color: var(--accent-cyan);
	}

	.skill-card:nth-child(2) .skill-icon {
		background: rgba(255, 0, 170, 0.1);
		color: var(--accent-magenta);
	}

	.skill-card:nth-child(2):hover .skill-icon {
		background: rgba(255, 0, 170, 0.2);
	}

	.skill-card:nth-child(3) .skill-icon {
		background: rgba(52, 211, 153, 0.1);
		color: #34d399;
	}

	.skill-card:nth-child(3):hover .skill-icon {
		background: rgba(52, 211, 153, 0.2);
	}

	.skill-title {
		font-size: 1rem;
		margin-bottom: 0.5rem;
		color: var(--text-primary);
	}

	.skill-desc {
		font-size: 0.85rem;
		color: var(--text-muted);
		line-height: 1.5;
	}

	/* ── Responsive ── */
	@media (max-width: 968px) {
		.about-grid {
			grid-template-columns: 1fr;
			gap: 2.5rem;
			text-align: center;
		}

		.about-photo {
			display: flex;
			justify-content: center;
		}

		.photo-frame {
			width: 220px;
			height: 220px;
		}

		.soft-skills {
			grid-template-columns: repeat(3, 1fr);
		}
	}

	@media (max-width: 640px) {
		.soft-skills {
			grid-template-columns: 1fr;
		}

		.photo-frame {
			width: 180px;
			height: 180px;
		}

		.photo-initials {
			font-size: 3rem;
		}

		.experience-badge {
			width: 64px;
			height: 64px;
			bottom: -8px;
			right: -8px;
		}

		.exp-number {
			font-size: 1.25rem;
		}

		.exp-label {
			font-size: 0.6rem;
		}
	}
</style>
