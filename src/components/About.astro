<script is:inline>
	document.addEventListener("DOMContentLoaded", () => {
		const photoFrame = document.querySelector(".photo-frame");
		const easterEgg = document.getElementById("easter-egg");
		const text = "Un buen desarrollador es aquel que encuentra soluciones a los problemas antes de que surjan.";
		let typing = false;
		let timeout = null;

		photoFrame?.addEventListener("mouseenter", () => {
			if (typing) return;
			typing = true;
			easterEgg.innerHTML = '<span class="cursor"></span>';
			let i = 0;

			function type() {
				if (i < text.length) {
					easterEgg.innerHTML = text.substring(0, i + 1) + '<span class="cursor"></span>';
					i++;
					timeout = setTimeout(type, 40 + Math.random() * 30);
				} else {
					easterEgg.innerHTML = text;
					typing = false;
				}
			}
			type();
		});

		photoFrame?.addEventListener("mouseleave", () => {
			clearTimeout(timeout);
			typing = false;
			easterEgg.innerHTML = "";
		});
	});
</script>

