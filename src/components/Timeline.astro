const prefersReducedMotion = typeof window !== "undefined" ? window.matchMedia("(prefers-reduced-motion: reduce)").matches : false
---

<script>
	function initTimeline() {
		const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches
		if (prefersReducedMotion) {
			// Make everything visible immediately
			document.querySelectorAll(".timeline-item").forEach((el) => el.classList.add("visible"))
			return
		}

		const section = document.getElementById("trayectoria")
		const items = section?.querySelectorAll(".timeline-item")
		const line = section?.querySelector(".timeline-line") as HTMLElement | null

		if (!items?.length) return

		// Reveal cards on scroll (bidirectional: re-animate when scrolling back up)
		const observer = new IntersectionObserver(
			(entries) => {
				entries.forEach((entry) => {
					if (entry.isIntersecting) {
						entry.target.classList.add("visible")
					} else {
						entry.target.classList.remove("visible")
					}
				})
			},
			{ threshold: 0.15, rootMargin: "0px 0px -60px 0px" },
		)

		items.forEach((item) => observer.observe(item))

		// Animate timeline line with scroll
		if (line) {
			const updateLine = () => {
				const rect = section!.getBoundingClientRect()
				const sectionHeight = rect.height
				const viewportHeight = window.innerHeight
				const scrolled = viewportHeight - rect.top
				const total = sectionHeight + viewportHeight
				const progress = Math.min(Math.max(scrolled / total, 0), 1)
				line.style.setProperty("--line-progress", `${progress * 100}%`)
			}

			window.addEventListener("scroll", updateLine, { passive: true })
			updateLine()
		}
	}

	// Run on DOM ready
	if (document.readyState === "loading") {
		document.addEventListener("DOMContentLoaded", initTimeline)
	} else {
		initTimeline()
	}

	// Also run on astro page transitions
	document.addEventListener("astro:page-load", initTimeline)
</script>

<section id="trayectoria" class="timeline-section section">
	<div class="container">
		<div class="section-title">
			<h2>Experiencia <span class="gradient-text">profesional</span></h2>
			<p>Los proyectos, desafíos y responsabilidades que han marcado mi crecimiento como profesional</p>
		</div>

		<div class="timeline">
			<div class="timeline-line"></div>
			{
				timeline.map((item, index) => (
					<div class={`timeline-item ${index % 2 === 0 ? "left" : "right"}`}>
						<div class="timeline-dot" />
						<div class="timeline-card glass-card">
							<span class="timeline-date">{item.date}</span>
							<h3 class="timeline-title">{item.title}</h3>
							<span class="timeline-subtitle">{item.subtitle}</span>
							<ul class="timeline-highlights">
								{item.highlights.map((h) => (
									<li>{h}</li>
								))}
							</ul>
						</div>
					</div>
				))
			}
		</div>

		<div class="section-cta">
			<a href="#skills" aria-label="Ir a stack tecnológico">
				<svg
					xmlns="http://www.w3.org/2000/svg"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-linecap="round"
					stroke-linejoin="round"
					aria-hidden="true"><path d="m6 9 6 6 6-6"></path></svg
				>
			</a>
		</div>
	</div>
</section>

<style>
	.timeline-section {
		overflow: hidden;
	}

	.timeline {
		position: relative;
		max-width: 900px;
		margin: 0 auto;
		padding: 2rem 0;
	}

	/* ── Animated timeline line ── */
	.timeline-line {
		position: absolute;
		left: 50%;
		top: 0;
		bottom: 0;
		width: 2px;
		background: rgba(255, 255, 255, 0.06);
		transform: translateX(-50%);
	}

	.timeline-line::after {
		content: "";
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: var(--line-progress, 0%);
		background: linear-gradient(180deg, var(--accent-cyan), var(--accent-magenta));
		box-shadow:
			0 0 12px rgba(0, 212, 255, 0.5),
			0 0 24px rgba(255, 0, 170, 0.3);
		transition: height 0.08s linear;
	}

	/* ── Timeline items (initial hidden state) ── */
	.timeline-item {
		position: relative;
		width: 50%;
		padding: 0 2.5rem 3rem;
	}

	.timeline-item.left {
		left: 0;
		padding-right: 2.5rem;
		padding-left: 0;
		text-align: right;
	}

	.timeline-item.right {
		left: 50%;
		padding-left: 2.5rem;
		padding-right: 0;
	}

	/* ── Timeline dots ── */
	.timeline-dot {
		position: absolute;
		top: 0.5rem;
		width: 14px;
		height: 14px;
		background: var(--accent-cyan);
		border: 3px solid var(--bg-primary);
		border-radius: 50%;
		z-index: 1;
		box-shadow: 0 0 12px rgba(0, 212, 255, 0.4);
	}

	.timeline-item.left .timeline-dot {
		right: -7px;
	}

	.timeline-item.right .timeline-dot {
		left: -7px;
	}

	/* ── Timeline cards ── */
	.timeline-card {
		padding: 1.5rem;
		text-align: left;
	}

	.timeline-date {
		display: inline-block;
		padding: 0.25rem 0.75rem;
		font-size: 0.75rem;
		font-weight: 600;
		color: var(--accent-cyan);
		background: rgba(0, 212, 255, 0.1);
		border: 1px solid rgba(0, 212, 255, 0.2);
		border-radius: var(--radius-full);
		margin-bottom: 0.75rem;
		letter-spacing: 0.03em;
	}

	.timeline-title {
		font-size: 1.15rem;
		margin-bottom: 0.25rem;
		color: var(--text-primary);
	}

	.timeline-subtitle {
		display: block;
		font-size: 0.85rem;
		color: var(--accent-magenta);
		font-weight: 500;
		margin-bottom: 0.75rem;
	}

	/* ── Highlights ── */
	.timeline-highlights {
		list-style: none;
		padding: 0;
		margin: 0 0 1rem;
		text-align: left;
	}

	.timeline-highlights li {
		position: relative;
		padding-left: 1rem;
		margin-bottom: 0.4rem;
		font-size: 0.85rem;
		color: var(--text-secondary);
		line-height: 1.5;
	}

	.timeline-highlights li::before {
		content: "▸";
		position: absolute;
		left: 0;
		color: var(--accent-cyan);
		font-weight: bold;
	}

	/* ═══════════════════════════════════════
	   GLOBAL: JS-driven animation classes
	   (bypass Astro scoped styles)
	   ═══════════════════════════════════════ */

	:global(.timeline-item) {
		opacity: 0;
		transition:
			opacity 0.6s ease,
			transform 0.6s ease;
	}

	:global(.timeline-item.left) {
		transform: translateX(-40px);
	}

	:global(.timeline-item.right) {
		transform: translateX(40px);
	}

	:global(.timeline-item.visible) {
		opacity: 1;
		transform: translateX(0);
	}

	:global(.timeline-item.visible .timeline-dot) {
		animation: dotPulse 2.5s ease-in-out infinite;
	}

	@keyframes dotPulse {
		0%,
		100% {
			box-shadow: 0 0 12px rgba(0, 212, 255, 0.4);
			transform: scale(1);
		}
		50% {
			box-shadow:
				0 0 20px rgba(0, 212, 255, 0.8),
				0 0 32px rgba(0, 212, 255, 0.3);
			transform: scale(1.15);
		}
	}

	:global(.timeline-item.left .timeline-card:hover) {
		transform: translateY(-4px) scale(1.02);
		box-shadow: 0 8px 32px rgba(0, 212, 255, 0.15);
		border-color: rgba(0, 212, 255, 0.3);
	}

	:global(.timeline-item.right .timeline-card:hover) {
		transform: translateY(-4px) scale(1.02);
		box-shadow: 0 8px 32px rgba(255, 0, 170, 0.15);
		border-color: rgba(255, 0, 170, 0.3);
	}

	/* ── Highlights staggered ── */
	:global(.timeline-highlights li) {
		opacity: 0;
		transform: translateX(-10px);
		transition:
			opacity 0.4s ease,
			transform 0.4s ease,
			color 0.2s ease;
	}

	:global(.timeline-item.visible .timeline-highlights li) {
		opacity: 1;
		transform: translateX(0);
	}

	:global(.timeline-item.visible .timeline-highlights li:nth-child(1)) {
		transition-delay: 0.25s;
	}
	:global(.timeline-item.visible .timeline-highlights li:nth-child(2)) {
		transition-delay: 0.35s;
	}
	:global(.timeline-item.visible .timeline-highlights li:nth-child(3)) {
		transition-delay: 0.45s;
	}
	:global(.timeline-item.visible .timeline-highlights li:nth-child(4)) {
		transition-delay: 0.55s;
	}
	:global(.timeline-item.visible .timeline-highlights li:nth-child(5)) {
		transition-delay: 0.65s;
	}
	:global(.timeline-item.visible .timeline-highlights li:nth-child(6)) {
		transition-delay: 0.75s;
	}

	:global(.timeline-highlights li:hover) {
		color: var(--text-primary);
	}

	:global(.timeline-highlights li:hover::before) {
		color: var(--accent-magenta);
	}

	/* ── Reduced motion ── */
	@media (prefers-reduced-motion: reduce) {
		:global(.timeline-item) {
			opacity: 1;
			transform: none;
			transition: none;
		}

		:global(.timeline-item.left),
		:global(.timeline-item.right) {
			transform: none;
		}

		.timeline-line::after {
			transition: none;
		}

		:global(.timeline-item.visible .timeline-dot) {
			animation: none;
		}

		:global(.timeline-highlights li) {
			opacity: 1;
			transform: none;
			transition: none;
		}

		:global(.timeline-card:hover) {
			transform: none;
		}
	}

	/* ── Mobile ── */
	@media (max-width: 768px) {
		.timeline-line {
			left: 20px;
		}

		.timeline-item {
			width: 100%;
			padding-left: 50px !important;
			padding-right: 0 !important;
			left: 0 !important;
			text-align: left !important;
		}

		:global(.timeline-item.left) {
			transform: translateX(40px);
		}

		:global(.timeline-item.right) {
			transform: translateX(40px);
		}

		:global(.timeline-item.visible) {
			transform: translateX(0);
		}

		.timeline-item .timeline-dot {
			left: 13px !important;
			right: auto !important;
		}
	}
</style>
