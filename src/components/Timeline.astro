---
const timeline = [
	{
		date: "Noviembre 2025 - Actualidad",
		title: "Líder de proyectos de ingeniería & Arquitectura de software",
		subtitle: "Consultoría Tecnológica Independiente",
		highlights: [
			"Implementación de metodologías de desarrollo basadas en LLMs en sinergia con Spec-Driven Development.",
			"Desarrollo centrado en el producto, priorizando la consistencia visual, la fluidez de navegación y una experiencia de interfaz (UI/UX) de primer nivel.",
			"Código robusto, escalable y documentado desde el diseño.",
			"Portabilidad y despliegue mediante Docker.",
		],
	},
	{
		date: "Diciembre 2019 - Octubre 2025",
		title: "Tech Lead | Desarrollador Full Stack",
		subtitle: "ShopShop - Desarrollo de software personalizado de sistemas de TI",
		highlights: [
			"Lideré el diseño, arquitectura y desarrollo de un ecosistema Fintech multiempresa de alto volumen, abarcando soluciones de pasarela de pagos (Hosted Checkout), motores de carrito de compras y plataformas de administración contable.",
			"Gestioné de extremo a extremo los ciclos de vida del pago (autorización, captura, anulación, reversa o reembolso).",
			"Implementé integraciones de pago de mayor complejidad incluyendo Unified Checkout, Click to Pay y CheckIn / Recargo / CheckOut, aceptando todas las billeteras digitales (Apple Pay, Google Pay, Click to Pay) incrementando el índice de autorización y disminuyendo el abandono de las compras en línea, mejorando la experiencia de pago.",
			"Diseñé y desarrollé de arquitecturas de API robustas y escalables, optimizando la comunicación entre el frontend y los sistemas backend para garantizar un rendimiento fluido.",
			"Optimicé el flujo de Documentos Tributarios Electrónicos (DTE/FEL) y la recuperación de transacciones, logrando automatizar el 90% de las operaciones fallidas que anteriormente requerían intervención manual.",
			"Aceleré el ciclo de venta al usuario final en un 30%, impactando directamente a la experiencia de compra.",
		],
	},
	{
		date: "Enero 2019 - Noviembre 2019",
		title: "Desarrollo de soluciones digitales autónomas",
		subtitle: "Consultoría Técnica Independiente",
		highlights: [
			"Desarrollo a medida de sitios web y secciones de blog corporativos.",
			"Sistema interno de control y flujo de inventario de vehículos.",
		],
	},
	{
		date: "Enero 2016 - Diciembre 2018",
		title: "Desarrollador Web | Diseñador Gráfico",
		subtitle: "El Camino Web - Soluciones digitales a medida",
		highlights: [
			"Optimicé el rendimiento y escalabilidad en múltiples proyectos.",
			"Diseñé, desarrollé y mantuve sitios estáticos y dinámicos.",
			"Refactoricé proyectos existentes hacia una arquitectura MVC, mejorando la mantenibilidad del código.",
		],
	},
]
---

<section id="trayectoria" class="timeline-section section">
	<div class="container">
		<div class="section-title">
			<h2><span class="gradient-text">Trayectoria</span></h2>
			<p>Mi recorrido profesional</p>
		</div>

		<div class="timeline">
			<div class="timeline-line"></div>
			{
				timeline.map((item, index) => (
					<div class={`timeline-item ${index % 2 === 0 ? "left" : "right"}`}>
						<div class="timeline-dot" />
						<div class="timeline-card glass-card">
							<span class="timeline-date">{item.date}</span>
							<h3 class="timeline-title">{item.title}</h3>
							<span class="timeline-subtitle">{item.subtitle}</span>
							<ul class="timeline-highlights">
								{item.highlights.map((h) => (
									<li>{h}</li>
								))}
							</ul>
						</div>
					</div>
				))
			}
		</div>

		<div class="section-cta">
			<a href="#skills" aria-label="Ir a stack tecnológico">
				<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
			</a>
		</div>
	</div>
</section>

<style>
	.timeline-section {
		overflow: hidden;
	}

	.timeline {
		position: relative;
		max-width: 900px;
		margin: 0 auto;
		padding: 2rem 0;
	}

	.timeline-line {
		position: absolute;
		left: 50%;
		top: 0;
		bottom: 0;
		width: 2px;
		background: linear-gradient(180deg, transparent, var(--accent-cyan), var(--accent-magenta), transparent);
		transform: translateX(-50%);
	}

	.timeline-item {
		position: relative;
		width: 50%;
		padding: 0 2.5rem 3rem;
	}

	.timeline-item.left {
		left: 0;
		padding-right: 2.5rem;
		padding-left: 0;
		text-align: right;
	}

	.timeline-item.right {
		left: 50%;
		padding-left: 2.5rem;
		padding-right: 0;
	}

	.timeline-dot {
		position: absolute;
		top: 0.5rem;
		width: 14px;
		height: 14px;
		background: var(--accent-cyan);
		border: 3px solid var(--bg-primary);
		border-radius: 50%;
		z-index: 1;
		box-shadow: 0 0 12px rgba(0, 212, 255, 0.4);
	}

	.timeline-item.left .timeline-dot {
		right: -7px;
	}

	.timeline-item.right .timeline-dot {
		left: -7px;
	}

	.timeline-card {
		padding: 1.5rem;
		text-align: left;
	}

	.timeline-date {
		display: inline-block;
		padding: 0.25rem 0.75rem;
		font-size: 0.75rem;
		font-weight: 600;
		color: var(--accent-cyan);
		background: rgba(0, 212, 255, 0.1);
		border: 1px solid rgba(0, 212, 255, 0.2);
		border-radius: var(--radius-full);
		margin-bottom: 0.75rem;
		letter-spacing: 0.03em;
	}

	.timeline-title {
		font-size: 1.15rem;
		margin-bottom: 0.25rem;
		color: var(--text-primary);
	}

	.timeline-subtitle {
		display: block;
		font-size: 0.85rem;
		color: var(--accent-magenta);
		font-weight: 500;
		margin-bottom: 0.75rem;
	}

	.timeline-highlights {
		list-style: none;
		padding: 0;
		margin: 0 0 1rem;
		text-align: left;
	}

	.timeline-highlights li {
		position: relative;
		padding-left: 1rem;
		margin-bottom: 0.4rem;
		font-size: 0.85rem;
		color: var(--text-secondary);
		line-height: 1.5;
	}

	.timeline-highlights li::before {
		content: "▸";
		position: absolute;
		left: 0;
		color: var(--accent-cyan);
		font-weight: bold;
	}

	@media (max-width: 768px) {
		.timeline-line {
			left: 20px;
		}

		.timeline-item {
			width: 100%;
			padding-left: 50px !important;
			padding-right: 0 !important;
			left: 0 !important;
			text-align: left !important;
		}

		.timeline-item .timeline-dot {
			left: 13px !important;
			right: auto !important;
		}
	}
</style>
