---
const timeline = [
	{
		date: "Noviembre 2025 - Actualidad",
		title: "Líder de proyectos de ingeniería & Arquitectura de software",
		subtitle: "Consultoría tecnológica independiente, Guatemala",
		description:
			"Implementación de metodologías de desarrollo basadas en LLMs en sinergia con Spec-Driven Development para garantizar código robusto, escalable y documentado desde el diseño, asegurando su portabilidad y despliegue mediante  Docker.",
	},
	{
		date: "Diciembre 2019 - Octubre 2025",
		title: "Tech Lead | Desarrollador Full Stack",
		subtitle: "ShopShop, Guatemala",
		description:
			"Desarrollo de aplicaciones web escalables con React, Node.js y Python. Implementación de arquitecturas microservicios.",
	},
	{
		date: "Enero 2019 - Noviembre 2019",
		title: "Desarrollo de soluciones autónomas",
		subtitle: "Consultoría técnica, Guatemala",
		description:
			"Construcción de APIs RESTful, integración de bases de datos y optimización de procesos operativos.",
	},
	{
		date: "Enero 2016 - Diciembre 2018",
		title: "Desarrollador web | Diseñador gráfico",
		subtitle: "El camino web, Guatemala",
		description:
			"Desarrollo de sitios web tipo blog y sistema interno para el control y flujo de inventario de vehículos.",
	},
]
---

<section id="trayectoria" class="timeline-section section">
	<div class="container">
		<div class="section-title">
			<h2><span class="gradient-text">Trayectoria</span></h2>
			<p>Mi recorrido profesional</p>
		</div>

		<div class="timeline">
			<div class="timeline-line"></div>
			{
				timeline.map((item, index) => (
					<div class={`timeline-item ${index % 2 === 0 ? "left" : "right"}`}>
						<div class="timeline-dot" />
						<div class="timeline-card glass-card">
							<span class="timeline-date">{item.date}</span>
							<h3 class="timeline-title">{item.title}</h3>
							<span class="timeline-subtitle">{item.subtitle}</span>
							<p class="timeline-description">{item.description}</p>
						</div>
					</div>
				))
			}
		</div>
	</div>
</section>

<style>
	.timeline-section {
		overflow: hidden;
	}

	.timeline {
		position: relative;
		max-width: 900px;
		margin: 0 auto;
		padding: 2rem 0;
	}

	.timeline-line {
		position: absolute;
		left: 50%;
		top: 0;
		bottom: 0;
		width: 2px;
		background: linear-gradient(180deg, transparent, var(--accent-cyan), var(--accent-magenta), transparent);
		transform: translateX(-50%);
	}

	.timeline-item {
		position: relative;
		width: 50%;
		padding: 0 2.5rem 3rem;
	}

	.timeline-item.left {
		left: 0;
		padding-right: 2.5rem;
		padding-left: 0;
		text-align: right;
	}

	.timeline-item.right {
		left: 50%;
		padding-left: 2.5rem;
		padding-right: 0;
	}

	.timeline-dot {
		position: absolute;
		top: 0.5rem;
		width: 14px;
		height: 14px;
		background: var(--accent-cyan);
		border: 3px solid var(--bg-primary);
		border-radius: 50%;
		z-index: 1;
		box-shadow: 0 0 12px rgba(0, 212, 255, 0.4);
	}

	.timeline-item.left .timeline-dot {
		right: -7px;
	}

	.timeline-item.right .timeline-dot {
		left: -7px;
	}

	.timeline-card {
		padding: 1.5rem;
		text-align: left;
	}

	.timeline-date {
		display: inline-block;
		padding: 0.25rem 0.75rem;
		font-size: 0.75rem;
		font-weight: 600;
		color: var(--accent-cyan);
		background: rgba(0, 212, 255, 0.1);
		border: 1px solid rgba(0, 212, 255, 0.2);
		border-radius: var(--radius-full);
		margin-bottom: 0.75rem;
		letter-spacing: 0.03em;
	}

	.timeline-title {
		font-size: 1.15rem;
		margin-bottom: 0.25rem;
		color: var(--text-primary);
	}

	.timeline-subtitle {
		display: block;
		font-size: 0.85rem;
		color: var(--accent-magenta);
		font-weight: 500;
		margin-bottom: 0.75rem;
	}

	.timeline-description {
		font-size: 0.9rem;
		color: var(--text-secondary);
		line-height: 1.6;
	}

	@media (max-width: 768px) {
		.timeline-line {
			left: 20px;
		}

		.timeline-item {
			width: 100%;
			padding-left: 50px !important;
			padding-right: 0 !important;
			left: 0 !important;
			text-align: left !important;
		}

		.timeline-item .timeline-dot {
			left: 13px !important;
			right: auto !important;
		}
	}
</style>
