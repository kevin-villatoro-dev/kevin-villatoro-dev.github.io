---

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@phosphor-icons/web@2.1.1/src/regular/style.css" />

<section id="skills" class="skills section">
	<div class="container">
		<div class="section-title">
			<h2>Stack & <span class="gradient-text">Herramientas</span></h2>
			<p>Tecnologías, plataformas y metodologías que utilizo para desarrollar soluciones de datos y software</p>
		</div>
		<div class="skills-bento">
			{
				categories.map((cat) => (
					<div class={`skill-bento-card ${cat.wide ? "wide" : ""}`}>
						<div class="skill-bento-header">
							<div class="skill-bento-icon" data-color={cat.color} set:html={cat.icon} />
						<h3 class="skill-bento-title">{cat.title}</h3>
						</div>
						<div class="skill-grid">
							{cat.skills.map((skill) => (
								<div class="tech-card">
									{skill.source === "skillicons" ? (
										<div class="tech-icon tech-icon-skillicons">
											<img
												src={`https://skillicons.dev/icons?i=${skill.iconId}&theme=dark`}
												alt=""
												width="44"
												height="44"
												loading="lazy"
											/>
										</div>
									) : skill.source === "simple" ? (
										<div class="tech-icon" style={`background: #${skill.color};`}>
											<img
												src={`https://cdn.simpleicons.org/${skill.slug}/ffffff`}
												alt=""
												width="20"
												height="20"
												loading="lazy"
											/>
										</div>
									) : (
										<div class="tech-icon tech-icon-phosphor">
											<i class={`ph ${skill.phClass}`} />
										</div>
									)}
									<span class="tech-card-name">{skill.name}</span>
								</div>
							))}
						</div>
					</div>
				))
			}
		</div>

		<div class="section-cta">
			<a href="#proyectos" aria-label="Ir a proyectos destacados">
				<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
			</a>
		</div>
	</div>
</section>

<style>
	.skills-bento {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1rem;
	}

	.skill-bento-card {
		padding: 1.5rem;
		overflow: hidden;
		background: var(--glass-bg);
		border: 1px solid var(--glass-border);
		border-radius: var(--radius-lg);
		box-shadow: var(--glass-shadow);
		transition: background 0.3s ease, border-color 0.3s ease;
	}

	.skill-bento-card:hover {
		background: var(--bg-card-hover);
		border-color: rgba(255, 255, 255, 0.12);
	}

	.skill-bento-card.wide {
		grid-column: span 3;
	}

	.skill-bento-header {
		display: flex;
		align-items: center;
		gap: 0.6rem;
		margin-bottom: 1.25rem;
	}

	.skill-bento-icon {
		width: 32px;
		height: 32px;
		display: flex;
		align-items: center;
		justify-content: center;
		border-radius: var(--radius-md);
		flex-shrink: 0;
	}

	[data-color="cyan"] {
		background: rgba(0, 212, 255, 0.1);
		color: var(--accent-cyan);
	}
	[data-color="magenta"] {
		background: rgba(255, 0, 170, 0.1);
		color: var(--accent-magenta);
	}
	[data-color="green"] {
		background: rgba(52, 211, 153, 0.1);
		color: var(--accent-green);
	}
	[data-color="purple"] {
		background: rgba(168, 85, 247, 0.1);
		color: var(--accent-purple);
	}

	.skill-bento-title {
		font-size: 0.9rem;
		font-weight: 600;
		color: var(--text-primary);
	}

	.skill-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(70px, 1fr));
		gap: 0.6rem;
	}

	.tech-card {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.5rem;
		padding: 0.7rem 0.4rem;
		border-radius: var(--radius-md);
		transition: transform 0.25s ease;
	}

	.tech-card:hover {
		transform: translateY(-2px);
	}

	.tech-icon {
		width: 44px;
		height: 44px;
		display: flex;
		align-items: center;
		justify-content: center;
		border-radius: var(--radius-md);
		flex-shrink: 0;
		transition: transform 0.25s ease, box-shadow 0.25s ease;
	}

	.tech-card:hover .tech-icon {
		transform: scale(1.08);
		box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
	}

	.tech-icon img {
		width: 20px;
		height: 20px;
	}

	.tech-icon-skillicons {
		background: none;
		padding: 0;
	}

	.tech-icon-skillicons img {
		width: 44px;
		height: 44px;
		border-radius: 12px;
	}

	.tech-icon-phosphor {
		background: var(--bg-icon-phosphor);
	}

	.tech-icon-phosphor :global(i) {
		font-size: 22px;
		color: white;
		line-height: 1;
	}

	.tech-card-name {
		font-size: 0.68rem;
		color: var(--text-muted);
		text-align: center;
		line-height: 1.2;
		word-break: break-word;
	}

	.tech-card:hover .tech-card-name {
		color: var(--text-secondary);
	}

	@media (max-width: 968px) {
		.skills-bento {
			grid-template-columns: repeat(2, 1fr);
		}
		.skill-bento-card.wide {
			grid-column: span 2;
		}
	}

	@media (max-width: 640px) {
		.skills-bento {
			grid-template-columns: 1fr;
		}
		.skill-bento-card.wide {
			grid-column: span 1;
		}
		.skill-grid {
			grid-template-columns: repeat(3, 1fr);
		}
	}
</style>
