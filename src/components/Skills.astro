</section>

<script>
	function initSkillsTabs() {
		const tabs = document.querySelectorAll(".skills-tab")
		const select = document.querySelector(".skills-select") as HTMLSelectElement
		const bento = document.querySelector(".skills-bento") as HTMLElement
		const stacksContainer = document.querySelector(".stacks-container") as HTMLElement
		const cards = document.querySelectorAll(".skill-bento-card") as NodeListOf<HTMLElement>

		if (!bento || !stacksContainer) return

		function filterSkills(filter: string) {
			if (filter === "stack") {
				bento.classList.add("hidden")
				stacksContainer.classList.remove("hidden")
			} else {
				stacksContainer.classList.add("hidden")
				bento.classList.remove("hidden")

				cards.forEach((card) => {
					const category = card.getAttribute("data-category")
					if (filter === "all" || category === filter) {
						card.classList.remove("hidden")
						card.style.opacity = "0"
						card.style.transform = "translateY(12px)"
						requestAnimationFrame(() => {
							requestAnimationFrame(() => {
								card.style.transition = "opacity 0.3s ease, transform 0.3s ease"
								card.style.opacity = "1"
								card.style.transform = "translateY(0)"
							})
						})
					} else {
						card.classList.add("hidden")
					}
				})
			}
		}

		tabs.forEach((tab) => {
			tab.addEventListener("click", () => {
				const filter = tab.getAttribute("data-filter")

				tabs.forEach((t) => {
					t.classList.remove("active")
					t.setAttribute("aria-selected", "false")
				})
				tab.classList.add("active")
				tab.setAttribute("aria-selected", "true")

				if (select) select.value = filter

				filterSkills(filter)
			})
		})

		if (select) {
			select.addEventListener("change", () => {
				const filter = select.value

				tabs.forEach((t) => {
					t.classList.remove("active")
					t.setAttribute("aria-selected", "false")
					if (t.getAttribute("data-filter") === filter) {
						t.classList.add("active")
						t.setAttribute("aria-selected", "true")
					}
				})

				filterSkills(filter)
			})
		}
	}

	document.addEventListener("DOMContentLoaded", initSkillsTabs)
</script>

<style>
	/* ── Tabs ── */
	.skills-tabs {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 0.25rem;
		margin-bottom: 2rem;
	}

	.skills-tab {
		background: none;
		border: none;
		color: var(--text-muted);
		font-family: var(--font-heading);
		font-size: 0.85rem;
		font-weight: 500;
		padding: 0.5rem 1rem;
		border-radius: var(--radius-sm);
		cursor: pointer;
		position: relative;
		transition:
			color 0.3s ease,
			background 0.3s ease;
	}

	.skills-tab::after {
		content: "";
		position: absolute;
		bottom: 0;
		left: 50%;
		width: 0;
		height: 2px;
		background: var(--accent-cyan);
		transition:
			width 0.3s ease,
			left 0.3s ease;
		border-radius: 1px;
	}

	.skills-tab:hover {
		color: var(--text-secondary);
		background: rgba(255, 255, 255, 0.04);
	}

	.skills-tab.active {
		color: var(--accent-cyan);
	}

	.skills-tab.active::after {
		width: 60%;
		left: 20%;
	}

	/* ── Mobile Dropdown ── */
	.skills-tabs-mobile {
		display: none;
		position: relative;
		max-width: 280px;
		margin: 0 auto 2rem;
	}

	.skills-select {
		width: 100%;
		appearance: none;
		background: var(--glass-bg);
		border: 1px solid var(--glass-border);
		border-radius: var(--radius-md);
		color: var(--text-primary);
		font-family: var(--font-heading);
		font-size: 0.9rem;
		font-weight: 500;
		padding: 0.75rem 2.5rem 0.75rem 1rem;
		cursor: pointer;
		transition:
			border-color 0.3s ease,
			background 0.3s ease;
	}

	.skills-select:hover {
		border-color: rgba(255, 255, 255, 0.15);
	}

	.skills-select:focus {
		outline: none;
		border-color: var(--accent-cyan);
	}

	.skills-select option {
		background: var(--bg-secondary);
		color: var(--text-primary);
		padding: 0.5rem;
	}

	.skills-select-icon {
		position: absolute;
		right: 1rem;
		top: 50%;
		transform: translateY(-50%);
		color: var(--text-muted);
		pointer-events: none;
		font-size: 1.1rem;
	}

	/* ── Bento Grid ── */
	.skills-bento {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1rem;
		transition: opacity 0.3s ease;
	}

	.skills-bento.hidden {
		display: none;
	}

	/* ── Stack Cards ── */
	.stacks-container {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		transition: opacity 0.3s ease;
	}

	.stacks-container.hidden {
		display: none;
	}

	.stack-card {
		padding: 1.5rem;
		background: var(--glass-bg);
		border: 1px solid var(--glass-border);
		border-radius: var(--radius-lg);
		box-shadow: var(--glass-shadow);
		transition:
			background 0.3s ease,
			border-color 0.3s ease;
	}

	.stack-card:hover {
		background: var(--bg-card-hover);
		border-color: rgba(255, 255, 255, 0.12);
	}

	.stack-title {
		font-size: 0.95rem;
		font-weight: 600;
		color: var(--text-primary);
		margin-bottom: 1rem;
		text-align: center;
	}

	.stack-grid {
		display: flex;
		justify-content: center;
		gap: 1.5rem;
		flex-wrap: wrap;
	}

	/* ── Category Cards ── */
	.skill-bento-card {
		padding: 1.5rem;
		overflow: hidden;
		background: var(--glass-bg);
		border: 1px solid var(--glass-border);
		border-radius: var(--radius-lg);
		box-shadow: var(--glass-shadow);
		transition:
			background 0.3s ease,
			border-color 0.3s ease,
			opacity 0.3s ease,
			transform 0.3s ease;
	}

	.skill-bento-card.hidden {
		display: none;
	}

	.skill-bento-card:hover {
		background: var(--bg-card-hover);
		border-color: rgba(255, 255, 255, 0.12);
	}

	.skill-bento-card.wide {
		grid-column: span 3;
	}

	.skill-bento-header {
		display: flex;
		align-items: center;
		gap: 0.6rem;
		margin-bottom: 1.25rem;
	}

	.skill-bento-icon {
		width: 32px;
		height: 32px;
		display: flex;
		align-items: center;
		justify-content: center;
		border-radius: var(--radius-md);
		flex-shrink: 0;
	}

	[data-color="cyan"] {
		background: rgba(0, 212, 255, 0.1);
		color: var(--accent-cyan);
	}
	[data-color="magenta"] {
		background: rgba(255, 0, 170, 0.1);
		color: var(--accent-magenta);
	}
	[data-color="green"] {
		background: rgba(52, 211, 153, 0.1);
		color: var(--accent-green);
	}
	[data-color="purple"] {
		background: rgba(168, 85, 247, 0.1);
		color: var(--accent-purple);
	}

	.skill-bento-title {
		font-size: 0.9rem;
		font-weight: 600;
		color: var(--text-primary);
	}

	/* ── Skill Grid ── */
	.skill-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(70px, 1fr));
		gap: 0.6rem;
	}

	/* ── Tech Card ── */
	.tech-card {
		display: flex;
		flex-direction: column;
