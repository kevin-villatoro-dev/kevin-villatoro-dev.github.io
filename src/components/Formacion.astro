---

---

<section id="formacion" class="formacion section">
	<div class="container">
		<div class="section-title">
			<h2><span class="gradient-text">Formación</span></h2>
			<p>Mi preparación académica</p>
		</div>

		<div class="edu-card">
			<div class="edu-glow" aria-hidden="true"></div>
			<div class="edu-icon">
				<svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
					<path d="M22 10v6M2 10l10-5 10 5-10 5z"/>
					<path d="M6 12v5c3 3 6 3 12 0v-5"/>
				</svg>
			</div>

			<div class="edu-content">
				<div class="edu-badge">En curso</div>
				<h3 class="edu-degree">Ingeniería en Sistemas de Información y Ciencias de la Computación</h3>
				<p class="edu-university">Universidad Mariano Gálvez de Guatemala</p>
				<div class="edu-progress">
					<div class="edu-progress-bar">
						<div class="edu-progress-fill"></div>
					</div>
					<span class="edu-progress-label">5° semestre</span>
				</div>
			</div>
		</div>
	</div>
</section>

<style>
	.formacion {
		overflow: hidden;
	}

	.edu-card {
		position: relative;
		display: flex;
		align-items: center;
		gap: 2.5rem;
		max-width: 700px;
		margin: 0 auto;
		padding: 2.5rem 3rem;
		background: var(--glass-bg);
		border: 1px solid var(--glass-border);
		border-radius: var(--radius-lg);
		overflow: hidden;
		transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.4s cubic-bezier(0.22, 1, 0.36, 1);
	}

	.edu-card::before {
		content: "";
		position: absolute;
		inset: 0;
		border-radius: var(--radius-lg);
		padding: 1px;
		background: conic-gradient(
			from var(--edu-angle, 0deg),
			transparent 0%,
			transparent 25%,
			var(--accent-cyan) 50%,
			transparent 75%,
			transparent 100%
		);
		-webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
		mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
		-webkit-mask-composite: xor;
		mask-composite: exclude;
		opacity: 0;
		transition: opacity 0.4s ease;
	}

	.edu-card:hover::before {
		opacity: 1;
		animation: eduBorderRotate 3s linear infinite;
	}

	@keyframes eduBorderRotate {
		to { --edu-angle: 360deg; }
	}

	@property --edu-angle {
		syntax: "<angle>";
		initial-value: 0deg;
		inherits: false;
	}

	.edu-card:hover {
		transform: translateY(-4px);
		box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
	}

	.edu-glow {
		position: absolute;
		top: -20%;
		left: -10%;
		width: 200px;
		height: 200px;
		background: var(--accent-cyan);
		border-radius: 50%;
		filter: blur(80px);
		opacity: 0.06;
		pointer-events: none;
	}

	.edu-icon {
		flex-shrink: 0;
		display: flex;
		align-items: center;
		justify-content: center;
		width: 80px;
		height: 80px;
		background: rgba(0, 212, 255, 0.08);
		border: 1px solid rgba(0, 212, 255, 0.15);
		border-radius: 50%;
		color: var(--accent-cyan);
		transition: transform 0.3s ease, border-color 0.3s ease;
	}

	.edu-card:hover .edu-icon {
		transform: scale(1.08);
		border-color: rgba(0, 212, 255, 0.3);
	}

	.edu-content {
		flex: 1;
		min-width: 0;
	}

	.edu-badge {
		display: inline-block;
		padding: 0.25rem 0.75rem;
		font-size: 0.7rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: #25d366;
		background: rgba(37, 211, 102, 0.1);
		border: 1px solid rgba(37, 211, 102, 0.2);
		border-radius: var(--radius-full);
		margin-bottom: 0.75rem;
	}

	.edu-degree {
		font-size: clamp(1.1rem, 2vw, 1.35rem);
		font-weight: 600;
		color: var(--text-primary);
		line-height: 1.3;
		margin-bottom: 0.35rem;
	}

	.edu-university {
		font-size: 0.9rem;
		color: var(--accent-magenta);
		font-weight: 500;
		margin-bottom: 1.25rem;
	}

	.edu-progress {
		display: flex;
		align-items: center;
		gap: 0.75rem;
	}

	.edu-progress-bar {
		flex: 1;
		height: 4px;
		background: rgba(255, 255, 255, 0.06);
		border-radius: 2px;
		overflow: hidden;
	}

	.edu-progress-fill {
		width: 42%;
		height: 100%;
		background: var(--accent-gradient);
		border-radius: 2px;
		animation: progressPulse 3s ease-in-out infinite;
	}

	@keyframes progressPulse {
		0%, 100% { opacity: 1; }
		50% { opacity: 0.7; }
	}

	.edu-progress-label {
		font-size: 0.75rem;
		font-weight: 600;
		color: var(--text-muted);
		white-space: nowrap;
	}

	/* ── Responsive ── */
	@media (max-width: 640px) {
		.edu-card {
			flex-direction: column;
			text-align: center;
			padding: 2rem 1.5rem;
			gap: 1.5rem;
		}

		.edu-progress {
			justify-content: center;
		}
	}
</style>
