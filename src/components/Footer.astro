---
const currentYear = new Date().getFullYear()
---

<footer class="footer">
	<div class="container">
		<div class="footer-inner">
			<div class="footer-gradient" aria-hidden="true"></div>
			<p class="footer-copy">
				&copy; {currentYear} Kevin Alberto Villatoro Arroyo &middot; Construido con <span class="gradient-text">Astro</span>
			</p>
		</div>
	</div>
</footer>

<style>
	.footer {
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 3rem 0 2rem;
	}

	.footer-inner {
		display: flex;
		flex-direction: column;
		align-items: center;
		width: 100%;
	}

	.footer-gradient {
		width: 100%;
		max-width: 600px;
		height: 1px;
		background: var(--accent-gradient);
		opacity: 0.4;
		margin-bottom: 2rem;
	}

	.footer-copy {
		text-align: center;
		font-size: 0.8rem;
		color: var(--text-muted);
		letter-spacing: 0.03em;
	}
</style>
