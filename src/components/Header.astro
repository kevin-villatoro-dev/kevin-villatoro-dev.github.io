---
---

<header class="header">
  <nav class="nav container">
    <a href="/" class="logo">
      <span class="logo-bracket">&lt;</span>
      <span class="logo-text">AM</span>
      <span class="logo-bracket">/&gt;</span>
    </a>
    <ul class="nav-links">
      <li><a href="#proyectos">Proyectos</a></li>
      <li><a href="#contacto">Contacto</a></li>
    </ul>
    <a href="#contacto" class="btn btn-primary nav-cta">Hablemos</a>
  </nav>
</header>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding: 1rem 0;
    background: rgba(10, 10, 15, 0.8);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--glass-border);
  }
  .nav { display: flex; align-items: center; justify-content: space-between; }
  .logo {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text-primary);
    display: flex;
    align-items: center;
    gap: 2px;
    transition: transform var(--transition-fast);
  }
  .logo:hover { transform: scale(1.05); color: var(--text-primary); }
  .logo-bracket { color: var(--accent-cyan); font-weight: 500; }
  .logo-text {
    background: var(--accent-gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .nav-links { display: flex; gap: 2rem; list-style: none; }
  .nav-links a {
    color: var(--text-secondary);
    font-weight: 500;
    position: relative;
    padding: 0.25rem 0;
  }
  .nav-links a::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--accent-gradient);
    transition: width var(--transition-normal);
  }
  .nav-links a:hover { color: var(--text-primary); }
  .nav-links a:hover::after { width: 100%; }
  .nav-cta { padding: 0.5rem 1.25rem; font-size: 0.9rem; }
  @media (max-width: 640px) {
    .nav-links { display: none; }
    .nav-cta { font-size: 0.85rem; padding: 0.5rem 1rem; }
  }
</style>
