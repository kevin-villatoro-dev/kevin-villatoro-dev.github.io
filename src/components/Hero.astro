<style>
	.hero {
		min-height: 100dvh;
		display: flex;
		align-items: center;
		padding-top: 6rem;
	}
	.hero .container {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 4rem;
		align-items: center;
	}
	.hero-greeting {
		font-size: 1.1rem;
		color: var(--accent-cyan);
		font-weight: 500;
		margin-bottom: 0.5rem;
		letter-spacing: 0.05em;
	}
	.hero-name {
		margin-bottom: 0.5rem;
		position: relative;
		display: inline-block;
	}
	.hero-name::after {
		content: "";
		position: absolute;
		bottom: -4px;
		left: 0;
		width: 100%;
		height: 3px;
		background: var(--accent-gradient);
		border-radius: 2px;
		transform: scaleX(0);
		transform-origin: left;
		animation: underline-slide 0.8s ease-out 0.5s forwards;
	}
	@keyframes underline-slide {
		to { transform: scaleX(1); }
	}
	.hero-title {
		color: var(--text-muted);
		font-weight: 500;
		margin-bottom: 1.5rem;
	}
	.hero-description {
		font-size: 1.1rem;
		max-width: 500px;
		margin-bottom: 2rem;
		line-height: 1.8;
	}
	.hero-visual {
		display: flex;
		justify-content: center;
		contain: layout style;
	}
	.code-block {
		width: 100%;
		max-width: 450px;
		padding: 0;
		overflow: hidden;
	}
	.code-block:hover {
		transform: none;
		box-shadow: var(--glass-shadow);
		backdrop-filter: none;
	}
	.code-header {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		padding: 1rem 1.25rem;
		background: rgba(0, 0, 0, 0.3);
		border-bottom: 1px solid var(--glass-border);
	}
	.dot {
		width: 12px;
		height: 12px;
		border-radius: 50%;
	}
	.dot.red { background: #ff5f57; }
	.dot.yellow { background: #ffbd2e; }
	.dot.green { background: #28c840; }
	.code-filename {
		margin-left: auto;
		font-size: 0.8rem;
		color: var(--text-muted);
		font-family: monospace;
	}
	.code-content {
		padding: 1.5rem;
		font-family: "SF Mono", "Fira Code", monospace;
		font-size: 0.85rem;
		line-height: 1.7;
		overflow-x: auto;
	}
	.keyword { color: var(--accent-magenta); }
	.variable { color: var(--accent-cyan); }
	.property { color: var(--accent-cyan); }
	.string { color: #34d399; }

	/* ── Hero Social ── */
	.hero-social {
		display: flex;
		gap: 1rem;
	}

	.hero-social-card {
		position: relative;
		display: flex;
		align-items: center;
		justify-content: center;
		width: 48px;
		height: 48px;
		background: var(--glass-bg);
		border: 1px solid var(--glass-border);
		border-radius: 50%;
		text-decoration: none;
		touch-action: manipulation;
		transition: background 0.3s ease, border-color 0.3s ease, transform 0.3s ease;
	}

	.hero-social-card:hover {
		background: var(--bg-card-hover);
		border-color: rgba(255, 255, 255, 0.12);
		transform: scale(1.1);
	}

	.hero-social-card:focus-visible {
		outline: 2px solid var(--accent-cyan);
		outline-offset: 2px;
	}

	.hs-ring {
		display: flex;
		align-items: center;
		justify-content: center;
		color: var(--text-secondary);
		transition: color 0.3s ease;
	}

	.hs-ring-email { color: #ea4335; }
	.hs-ring-linkedin { color: #0a66c2; }
	.hs-ring-github { color: #f0f0f0; }
	.hs-ring-whatsapp { color: #25d366; }

	.hs-copy {
		position: absolute;
		top: -2px;
		right: -2px;
		z-index: 2;
		display: flex;
		align-items: center;
		justify-content: center;
		width: 20px;
		height: 20px;
		background: var(--bg-secondary);
		border: 1px solid var(--glass-border);
		border-radius: 50%;
		color: var(--text-muted);
		cursor: pointer;
		opacity: 0;
		touch-action: manipulation;
		transition: opacity 0.2s ease, background 0.2s ease, color 0.2s ease;
	}

	.hero-social-card:hover .hs-copy,
	.hero-social-card:focus-within .hs-copy {
		opacity: 1;
	}

	@media (hover: none) {
		.hs-copy {
			opacity: 1;
		}
	}

	.hs-copy:hover {
		background: rgba(0, 212, 255, 0.15);
		color: var(--accent-cyan);
	}

	.hs-copy:focus-visible {
		outline: 2px solid var(--accent-cyan);
		outline-offset: 1px;
	}

	.hs-copy .icon-check { display: none; }
	.hs-copy.copied .icon-copy { display: none; }
	.hs-copy.copied .icon-check { display: block; color: #25d366; }
	.hs-copy.copied {
		background: rgba(37, 211, 102, 0.15);
		border-color: rgba(37, 211, 102, 0.3);
	}

	/* ── Animations ── */
	.anim-float-shimmer {
		position: relative;
		overflow: hidden;
		animation: float 4s ease-in-out infinite;
		will-change: transform;
	}
	.anim-float-shimmer::before {
		content: "";
		position: absolute;
		top: 0;
		left: -100%;
		width: 100%;
		height: 100%;
		background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.1), transparent);
		animation: shimmer 4s infinite;
		will-change: transform;
	}
	@keyframes float {
		0%, 100% { transform: translateY(0); }
		50% { transform: translateY(-12px); }
	}
	@keyframes shimmer {
		0% { left: -100%; }
		100% { left: 100%; }
	}

	/* ── Responsive ── */
	@media (max-width: 968px) {
		.hero .container {
			grid-template-columns: 1fr;
			text-align: center;
		}
		.hero-description {
			margin-left: auto;
			margin-right: auto;
		}
		.code-block { max-width: 400px; }
	}
</style>
