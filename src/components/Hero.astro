<script>
	window.addEventListener("preloader:done", () => {
		const glitchEls = document.querySelectorAll(".glitch-hero")
		glitchEls.forEach((el, i) => {
			setTimeout(() => {
				el.classList.add("glitch-active")
			}, i * 150)
		})

		const titleEls = document.querySelectorAll(".hero-title-segment")
		titleEls.forEach((el, i) => {
			setTimeout(() => {
				el.classList.add("segment-active")
			}, 300 + i * 200)
		})
	})
</script>

