---

<section class="hero section">
	<div class="container">
		<div class="hero-content">
			<p class="hero-greeting">Hola, soy</p>
			<h1 class="hero-name">
				<span class="gradient-text">Kevin</span><br />Villatoro
			</h1>
			<h2 class="hero-title">Ingeniero de Software</h2>
			<div class="hero-roles">
				<span class="role-tag">Tech Lead</span>
				<span class="role-tag">Project Manager IT</span>
				<span class="role-tag">Backend Developer</span>
				<span class="role-tag">Frontend Developer</span>
				<span class="role-tag">Data Base Administrator (DBA)</span>
			</div>
			<p class="hero-description">
				Profesional de TI enfocado en la entrega de valor End-to-End y
				la optimización de procesos operativos. Experto en liderar el
				diseño técnico, la ejecución de portafolios tecnológicos y el
				ciclo completo de despliegue de aplicaciones. Con una mentalidad
				orientada a la mejora continua y la gestión del cambio, facilito
				la adopción de tecnologías emergentes como LLMs, transformando
				la complejidad técnica en sistemas eficientes, automatizados y
				listos para el futuro.
			</p>
			<div class="hero-actions">
				<a href="#proyectos" class="btn btn-primary">
					<svg
						xmlns="http://www.w3.org/2000/svg"
						width="18"
						height="18"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
						><path
							d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"
						></path></svg
					>
					<span>Ver proyectos</span>
				</a>
				<a href="#contacto" class="btn btn-outline">
					<svg
						xmlns="http://www.w3.org/2000/svg"
						width="18"
						height="18"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
						><path
							d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
						></path><polyline points="22,6 12,13 2,6"
						></polyline></svg
					>
					Contáctame
				</a>
			</div>
		</div>
		<div class="hero-visual">
			<div class="code-block glass-card anim-float-shimmer">
				<div class="code-header">
					<span class="dot red"></span>
					<span class="dot yellow"></span>
					<span class="dot green"></span>
					<span class="code-filename">engineer.ts</span>
				</div>
<pre class="code-content"><code><span class="keyword">const</span> <span class="variable">engineer</span> = {'{'}
    <span class="property">name</span>: <span class="string">"Kevin Villatoro"</span>,
    <span class="property">role</span>: <span class="string">"Ingeniero de Software"</span>,
    <span class="property">languages</span>: [
        <span class="string">"PHP"</span>, <span class="string">"JavaScript"</span>, <span class="string">"TypeScript"</span>,
        <span class="string">"Python"</span>, <span class="string">"Java"</span>, <span class="string">"C#"</span>
    ],
    <span class="property">frameworks</span>: [
        <span class="string">"Laravel"</span>, <span class="string">"Node.js"</span>, <span class="string">"React"</span>,
        <span class="string">"Next.js"</span>, <span class="string">"Django"</span>, <span class="string">"Flask"</span>
    ],
    <span class="property">tools</span>: [
        <span class="string">"Docker"</span>, <span class="string">"Git"</span>, <span class="string">"CI/CD"</span>,
        <span class="string">"MySQL"</span>, <span class="string">"PostgreSQL"</span>
    ],
    <span class="property">passion</span>: <span class="string">"Building the future"</span>
{'}'}
</code></pre>
			</div>
		</div>
	</div>
</section>

<style>
	.hero {
		min-height: 100vh;
		display: flex;
		align-items: center;
		padding-top: 6rem;
	}
	.hero .container {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 4rem;
		align-items: center;
	}
	.hero-greeting {
		font-size: 1.1rem;
		color: var(--accent-cyan);
		font-weight: 500;
		margin-bottom: 0.5rem;
		letter-spacing: 0.05em;
	}
	.hero-name {
		margin-bottom: 0.5rem;
	}
	.hero-title {
		color: var(--text-muted);
		font-weight: 500;
		margin-bottom: 1.5rem;
	}
	.hero-roles {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		margin-bottom: 1.5rem;
	}
	.hero-description {
		font-size: 1.1rem;
		max-width: 500px;
		margin-bottom: 2rem;
		line-height: 1.8;
	}
	.hero-actions {
		display: flex;
		gap: 1rem;
		margin-bottom: 3rem;
	}
	.role-tag {
		padding: 0.5rem 1rem;
		font-size: 0.85rem;
		font-weight: 500;
		color: var(--accent-cyan);
		background: rgba(0, 212, 255, 0.08);
		border: 1px solid rgba(0, 212, 255, 0.2);
		border-radius: var(--radius-full);
		transition: all var(--transition-normal);
	}
	.role-tag:hover {
		background: rgba(0, 212, 255, 0.15);
		border-color: var(--accent-cyan);
		transform: translateY(-2px);
	}
	.hero-visual {
		display: flex;
		justify-content: center;
	}
	.code-block {
		width: 100%;
		max-width: 450px;
		padding: 0;
		overflow: hidden;
	}
	.code-header {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		padding: 1rem 1.25rem;
		background: rgba(0, 0, 0, 0.3);
		border-bottom: 1px solid var(--glass-border);
	}
	.dot {
		width: 12px;
		height: 12px;
		border-radius: 50%;
	}
	.dot.red {
		background: #ff5f57;
	}
	.dot.yellow {
		background: #ffbd2e;
	}
	.dot.green {
		background: #28c840;
	}
	.code-filename {
		margin-left: auto;
		font-size: 0.8rem;
		color: var(--text-muted);
		font-family: monospace;
	}
	.code-content {
		padding: 1.5rem;
		font-family: "SF Mono", "Fira Code", monospace;
		font-size: 0.85rem;
		line-height: 1.7;
		overflow-x: auto;
	}
	.keyword {
		color: var(--accent-magenta);
	}
	.variable {
		color: var(--accent-cyan);
	}
	.property {
		color: #a78bfa;
	}
	.string {
		color: #34d399;
	}

	/* Combined Animation: Float + Shimmer */
	.anim-float-shimmer {
		position: relative;
		overflow: hidden;
		animation: float 6s ease-in-out infinite;
	}

	.anim-float-shimmer::before {
		content: "";
		position: absolute;
		top: 0;
		left: -100%;
		width: 100%;
		height: 100%;
		background: linear-gradient(
			90deg,
			transparent,
			rgba(255, 255, 255, 0.15),
			transparent
		);
		animation: shimmer 3s infinite;
	}

	@keyframes float {
		0%,
		100% {
			transform: translateY(0);
		}
		50% {
			transform: translateY(-10px);
		}
	}

	@keyframes shimmer {
		0% {
			left: -100%;
		}
		100% {
			left: 100%;
		}
	}

	@media (max-width: 968px) {
		.hero .container {
			grid-template-columns: 1fr;
			text-align: center;
		}
		.hero-description {
			margin-left: auto;
			margin-right: auto;
		}
		.hero-actions {
			justify-content: center;
		}
		.hero-roles {
			justify-content: center;
		}
		.hero-visual {
			order: -1;
		}
		.code-block {
			max-width: 400px;
		}
	}
	@media (max-width: 480px) {
		.hero-roles {
			flex-direction: column;
			align-items: center;
		}
	}
</style>
