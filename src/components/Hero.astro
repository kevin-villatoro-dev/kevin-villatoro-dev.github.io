<style>
	.hero {
		min-height: 100dvh;
		display: flex;
		flex-direction: column;
		padding-top: 6rem;
		position: relative;
		overflow: hidden;
		scroll-margin-top: 5rem;
	}
	.hero .container {
		flex: 1;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		text-align: center;
		position: relative;
		z-index: 1;
	}
	.hero-content {
		width: 100%;
		max-width: 800px;
		display: flex;
		flex-direction: column;
		align-items: center;
	}
	.hero .section-cta {
		position: absolute;
		bottom: 0;
		left: 0;
		right: 0;
	}
	.hero-name {
		margin-bottom: 0.5rem;
		position: relative;
		display: inline-block;
	}

	/* ── Glitch Hero Name ── */
	.glitch-hero {
		position: relative;
		display: inline-block;
		color: var(--text-primary);
		opacity: 0;
		transform: translateY(10px);
	}

	.glitch-hero.glitch-active {
		animation: heroGlitchIn 0.8s cubic-bezier(0.22, 1, 0.36, 1) forwards;
	}

	.glitch-hero::before,
	.glitch-hero::after {
		content: attr(data-text);
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		opacity: 0;
	}

	.glitch-hero::before {
		color: var(--accent-cyan);
		clip-path: polygon(0 0, 100% 0, 100% 40%, 0 40%);
	}

	.glitch-hero::after {
		color: var(--accent-magenta);
		clip-path: polygon(0 60%, 100% 60%, 100% 100%, 0 100%);
	}

	.glitch-hero.glitch-active::before {
		animation: heroGlitchLayerCyan 0.6s ease-out forwards;
	}

	.glitch-hero.glitch-active::after {
		animation: heroGlitchLayerMagenta 0.6s ease-out forwards;
	}

	@keyframes heroGlitchIn {
		0% {
			opacity: 0;
			transform: translateY(10px);
		}
		15% {
			opacity: 1;
			transform: translateY(0) skewX(-3deg);
		}
		25% {
			transform: skewX(4deg);
		}
		35% {
			transform: skewX(-2deg);
		}
		45% {
			transform: skewX(1deg);
		}
		55% {
			transform: skewX(0);
		}
		100% {
			opacity: 1;
			transform: translateY(0) skewX(0);
		}
	}

	@keyframes heroGlitchLayerCyan {
		0% {
			opacity: 0;
			transform: translate(0);
		}
		10% {
			opacity: 0.8;
			transform: translate(-4px, 2px);
		}
		20% {
			transform: translate(4px, -1px);
		}
		30% {
			opacity: 0.6;
			transform: translate(-3px, 1px);
		}
		40% {
			transform: translate(2px, -2px);
		}
		50% {
			opacity: 0;
			transform: translate(0);
		}
		100% {
			opacity: 0;
			transform: translate(0);
		}
	}

	@keyframes heroGlitchLayerMagenta {
		0% {
			opacity: 0;
			transform: translate(0);
		}
		10% {
			opacity: 0.8;
			transform: translate(4px, -2px);
		}
		20% {
			transform: translate(-4px, 1px);
		}
		30% {
			opacity: 0.6;
			transform: translate(3px, -1px);
		}
		40% {
			transform: translate(-2px, 2px);
		}
		50% {
			opacity: 0;
			transform: translate(0);
		}
		100% {
			opacity: 0;
			transform: translate(0);
		}
	}
	.hero-title {
		color: var(--text-muted);
		font-weight: 500;
		margin-bottom: 1.5rem;
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
	}

	.hero-title-dot {
		color: var(--text-muted);
		opacity: 0.4;
	}

	.hero-title-segment {
		opacity: 0;
		transform: translateY(8px);
		transition:
			opacity 0.5s ease,
			transform 0.5s ease;
		transition-delay: calc(var(--i) * 0.15s);
	}

	.hero-title-segment.segment-active {
		opacity: 1;
		transform: translateY(0);
	}

	.segment-cyan {
		color: var(--accent-cyan);
	}
	.segment-magenta {
		color: var(--accent-magenta);
	}
	.segment-green {
		color: var(--accent-green);
	}
	.segment-purple {
		color: var(--accent-purple);
	}

	@media (prefers-reduced-motion: reduce) {
		.hero-title-segment {
			opacity: 1;
			transform: none;
			transition: none;
		}
	}
	.hero-actions {
		display: flex;
		gap: 1rem;
		margin-bottom: 1.5rem;
		justify-content: center;
		align-items: center;
		flex-wrap: wrap;
	}
	.btn-hero {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.75rem 1.5rem;
		font-size: 0.95rem;
		font-weight: 500;
		border-radius: var(--radius-full);
		text-decoration: none;
		cursor: pointer;
		touch-action: manipulation;
		transition:
			transform 0.3s ease,
			box-shadow 0.3s ease;
	}
	.btn-hero:hover {
		transform: translateY(-2px);
	}
	.btn-hero:focus-visible {
		outline: 2px solid var(--accent-cyan);
		outline-offset: 2px;
	}
	.btn-hero-magenta {
		background: var(--accent-magenta);
		color: var(--bg-primary);
	}
	.btn-hero-magenta:hover {
		box-shadow: 0 8px 24px rgba(255, 0, 170, 0.3);
		color: var(--bg-primary);
	}
	.btn-hero-cyan {
		background: var(--accent-cyan);
		color: var(--bg-primary);
	}
	.btn-hero-cyan:hover {
		box-shadow: 0 8px 24px rgba(0, 212, 255, 0.3);
		color: var(--bg-primary);
	}
	.hero-description {
		font-size: 1.1rem;
		max-width: 600px;
		margin-inline: auto;
		margin-bottom: 1.5rem;
		line-height: 1.8;
	}

	.particle-canvas {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		pointer-events: none;
	}

	/* ── Responsive ── */
	@media (max-width: 968px) {
		.hero-title {
			justify-content: center;
		}
		.hero-actions {
			justify-content: center;
		}
	}
</style>
